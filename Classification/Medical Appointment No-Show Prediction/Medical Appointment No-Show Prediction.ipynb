    "   \"source\": [\n",
    "    \"# !pip install pandas numpy scikit-learn matplotlib seaborn lazypredict flaml kagglehub --quiet\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Imports\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import os, glob, warnings\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib\\n\",\n",
    "    \"matplotlib.use('Agg')\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"from sklearn.model_selection import train_test_split\\n\",\n",
    "    \"from sklearn.preprocessing import LabelEncoder\\n\",\n",
    "    \"from sklearn.linear_model import LogisticRegression\\n\",\n",
    "    \"from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier, ExtraTreesClassifier\\n\",\n",
    "    \"from sklearn.metrics import (accuracy_score, precision_score, recall_score, f1_score,\\n\",\n",
    "    \"                             confusion_matrix, classification_report, roc_auc_score,\\n\",\n",
    "    \"                             average_precision_score, roc_curve)\\n\",\n",
    "    \"from lazypredict.Supervised import LazyClassifier\\n\",\n",
    "    \"from flaml import AutoML\\n\",\n",
    "    \"\\n\",\n",
    "    \"warnings.filterwarnings('ignore')\\n\",\n",
    "    \"sns.set_style('whitegrid')\\n\",\n",
    "    \"plt.rcParams['figure.figsize'] = (10, 6)\\n\",\n",
    "    \"print('Imports successful.')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Configuration / Constants\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"RANDOM_STATE = 42\\n\",\n",
    "    \"TEST_SIZE = 0.2\\n\",\n",
    "    \"FLAML_TIME_BUDGET = 120\\n\",\n",
    "    \"MAX_ROWS = 50000\\n\",\n",
    "    \"np.random.seed(RANDOM_STATE)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Dataset Download and Loading\\n\",\n",
    "    \"\\n\",\n",
    "    \"We download the dataset from Kaggle using `kagglehub` (primary) with a fallback to `opendatasets`. The dataset is sampled to 50,000 rows if larger to keep training times reasonable.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"dataset_path = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    import kagglehub\\n\",\n",
    "    \"    path = kagglehub.dataset_download('joniarroba/noshowappointments')\\n\",\n",
    "    \"    csvs = glob.glob(os.path.join(path, '**', '*.csv'), recursive=True)\\n\",\n",
    "    \"    if csvs:\\n\",\n",
    "    \"        dataset_path = csvs[0]\\n\",\n",
    "    \"        print(f'Downloaded via kagglehub: {dataset_path}')\\n\",\n",
    "    \"except Exception as e:\\n\",\n",
    "    \"    print(f'kagglehub failed: {e}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"if dataset_path is None:\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        import opendatasets as od\\n\",\n",
    "    \"        od.download('https://www.kaggle.com/datasets/joniarroba/noshowappointments')\\n\",\n",
    "    \"        csvs = glob.glob('noshowappointments/*.csv')\\n\",\n",
    "    \"        if csvs:\\n\",\n",
    "    \"            dataset_path = csvs[0]\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        print(f'opendatasets failed: {e}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"if dataset_path is None:\\n\",\n",
    "    \"    raise FileNotFoundError('Download the dataset from https://www.kaggle.com/datasets/joniarroba/noshowappointments')\\n\",\n",
    "    \"\\n\",\n",
    "    \"df = pd.read_csv(dataset_path)\\n\",\n",
    "    \"if len(df) > MAX_ROWS:\\n\",\n",
    "    \"    df = df.sample(n=MAX_ROWS, random_state=RANDOM_STATE).reset_index(drop=True)\\n\",\n",
    "    \"    print(f'Sampled to {MAX_ROWS} rows')\\n\",\n",
    "    \"print(f'Shape: {df.shape}')\\n\",\n",
    "    \"df.head()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Data Validation Checks\\n\",\n",
    "    \"\\n\",\n",
    "    \"Before doing anything, we check for missing values, duplicates, and data types to understand what cleaning is needed.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(f'Shape: {df.shape}')\\n\",\n",
    "    \"print(f'\\\\nDtypes:\\\\n{df.dtypes}')\\n\",\n",
    "    \"print(f'\\\\nMissing values per column:')\\n\",\n",
    "    \"missing = df.isnull().sum()\\n\",\n",
    "    \"if missing.sum() == 0:\\n\",\n",
    "    \"    print('  No missing values found.')\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(missing[missing > 0])\\n\",\n",
    "    \"print(f'\\\\nDuplicate rows: {df.duplicated().sum()}')\\n\",\n",
    "    \"df.describe()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Data Cleaning\\n\",\n",
    "    \"\\n\",\n",
    "    \"Strip whitespace from column names and handle any negative ages (known data quality issue in this dataset).\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Fix column names — strip whitespace\\n\",\n",
    "    \"df.columns = df.columns.str.strip()\\n\",\n",
    "    \"print(f'Columns: {list(df.columns)}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Fix negative ages (known issue)\\n\",\n",
    "    \"if 'Age' in df.columns:\\n\",\n",
    "    \"    neg_age = (df['Age'] < 0).sum()\\n\",\n",
    "    \"    if neg_age > 0:\\n\",\n",
    "    \"        print(f'Removing {neg_age} rows with negative Age')\\n\",\n",
    "    \"        df = df[df['Age'] >= 0].reset_index(drop=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Drop exact duplicates if any\\n\",\n",
    "    \"n_dup = df.duplicated().sum()\\n\",\n",
    "    \"if n_dup > 0:\\n\",\n",
    "    \"    print(f'Dropping {n_dup} duplicate rows')\\n\",\n",
    "    \"    df = df.drop_duplicates().reset_index(drop=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f'Clean shape: {df.shape}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Exploratory Data Analysis\\n\",\n",
    "    \"\\n\",\n",
    "    \"We visualize the target distribution and key features to understand the class imbalance and feature characteristics.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Find the target column\\n\",\n",
    "    \"target_col = [c for c in df.columns if 'no' in c.lower() and 'show' in c.lower()]\\n\",\n",
    "    \"TARGET = target_col[0] if target_col else 'No-show'\\n\",\n",
    "    \"print(f'Target column: {TARGET}')\\n\",\n",
    "    \"print(f'\\\\nTarget distribution:\\\\n{df[TARGET].value_counts()}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, axes = plt.subplots(1, 2, figsize=(14, 5))\\n\",\n",
    "    \"df[TARGET].value_counts().plot(kind='bar', ax=axes[0], color=['steelblue', 'coral'], edgecolor='black')\\n\",\n",
    "    \"axes[0].set_title('No-Show Distribution')\\n\",\n",
    "    \"axes[0].set_ylabel('Count')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Age distribution\\n\",\n",
    "    \"if 'Age' in df.columns:\\n\",\n",
    "    \"    df['Age'].hist(bins=30, ax=axes[1], edgecolor='black', alpha=0.7)\\n\",\n",
    "    \"    axes[1].set_title('Age Distribution')\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Correlation Heatmap\\n\",\n",
    "    \"\\n\",\n",
    "    \"Check linear relationships between numeric features. Note that weak correlation does not mean a feature is useless — non-linear models can still exploit it.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"num_cols = df.select_dtypes(include='number').columns.tolist()\\n\",\n",
    "    \"if len(num_cols) > 1:\\n\",\n",
    "    \"    plt.figure(figsize=(10, 8))\\n\",\n",
    "    \"    sns.heatmap(df[num_cols].corr(), annot=True, cmap='coolwarm', fmt='.2f', center=0)\\n\",\n",
    "    \"    plt.title('Correlation Heatmap')\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### No-Show Rate by Key Features\\n\",\n",
    "    \"\\n\",\n",
    "    \"Visualize no-show rates across different categories to build intuition about which features matter.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Temporary binary flag for aggregation\\n\",\n",
    "    \"df['_noshow_flag'] = (df[TARGET].str.strip().str.lower() == 'yes').astype(int)\\n\",\n",
    "    \"\\n\",\n",
    "    \"cat_features = ['Gender', 'Scholarship', 'SMS_received']\\n\",\n",
    "    \"cat_features = [c for c in cat_features if c in df.columns]\\n\",\n",
    "    \"\\n\",\n",
    "    \"if cat_features:\\n\",\n",
    "    \"    fig, axes = plt.subplots(1, len(cat_features), figsize=(6 * len(cat_features), 5))\\n\",\n",
    "    \"    if len(cat_features) == 1:\\n\",\n",
    "    \"        axes = [axes]\\n\",\n",
    "    \"    for ax, col in zip(axes, cat_features):\\n\",\n",
    "    \"        rates = df.groupby(col)['_noshow_flag'].mean()\\n\",\n",
    "    \"        rates.plot(kind='bar', ax=ax, color='coral', edgecolor='black', alpha=0.8)\\n\",\n",
    "    \"        ax.set_title(f'No-Show Rate by {col}')\\n\",\n",
    "    \"        ax.set_ylabel('No-Show Rate')\\n\",\n",
    "    \"        ax.set_ylim(0, 0.5)\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"df.drop(columns=['_noshow_flag'], inplace=True)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Target Encoding\\n\",\n",
    "    \"\\n\",\n",
    "    \"Encode the target: `No-show = Yes` → 1 (missed), `No-show = No` → 0 (showed up).\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"df['target'] = (df[TARGET].str.strip().str.lower() == 'yes').astype(int)\\n\",\n",
    "    \"print(f'Target (encoded):\\\\n{df[\\\"target\\\"].value_counts()}')\\n\",\n",
    "    \"print(f'No-show rate: {df[\\\"target\\\"].mean():.2%}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Feature Engineering\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Lead Time\\n\",\n",
    "    \"\\n\",\n",
    "    \"The **lead time** (number of days between when the appointment was scheduled and the actual appointment date) is one of the strongest predictors of no-shows. Patients with longer lead times are more likely to forget or have schedule conflicts.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Parse date columns and engineer lead_time_days\\n\",\n",
    "    \"sched_col = [c for c in df.columns if 'scheduled' in c.lower()]\\n\",\n",
    "    \"appt_col = [c for c in df.columns if 'appointment' in c.lower() and 'id' not in c.lower()]\\n\",\n",
    "    \"\\n\",\n",
    "    \"if sched_col and appt_col:\\n\",\n",
    "    \"    sched_name = sched_col[0]\\n\",\n",
    "    \"    appt_name = appt_col[0]\\n\",\n",
    "    \"    df[sched_name] = pd.to_datetime(df[sched_name], errors='coerce')\\n\",\n",
    "    \"    df[appt_name] = pd.to_datetime(df[appt_name], errors='coerce')\\n\",\n",
    "    \"    df['lead_time_days'] = (df[appt_name] - df[sched_name]).dt.days\\n\",\n",
    "    \"    # Extract useful calendar features\\n\",\n",
    "    \"    df['sched_dayofweek'] = df[sched_name].dt.dayofweek\\n\",\n",
    "    \"    df['sched_hour'] = df[sched_name].dt.hour\\n\",\n",
    "    \"    df['appt_dayofweek'] = df[appt_name].dt.dayofweek\\n\",\n",
    "    \"    df['appt_month'] = df[appt_name].dt.month\\n\",\n",
    "    \"    print(f'Lead time stats:\\\\n{df[\\\"lead_time_days\\\"].describe()}')\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print('Date columns not found — skipping lead_time_days')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Clip negative lead times to 0 (same-day scheduling edge cases)\\n\",\n",
    "    \"if 'lead_time_days' in df.columns:\\n\",\n",
    "    \"    df['lead_time_days'] = df['lead_time_days'].clip(lower=0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f'\\\\nNew columns added: {[c for c in df.columns if c in [\\\"lead_time_days\\\", \\\"sched_dayofweek\\\", \\\"sched_hour\\\", \\\"appt_dayofweek\\\", \\\"appt_month\\\"]]}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Train / Test Split\\n\",\n",
    "    \"\\n\",\n",
    "    \"We drop ID columns, raw date columns, and the original target string column. The engineered features (lead time, calendar features) are kept.\\n\",\n",
    "    \"\\n\",\n",
    "    \"> **Note**: We identify date columns by dtype (datetime64) to drop them cleanly after feature extraction.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Columns to drop: IDs, raw target, original date columns\\n\",\n",
    "    \"id_cols = [c for c in df.columns if 'id' in c.lower()]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Find raw date columns (datetime dtype) — we already extracted features from them\\n\",\n",
    "    \"date_cols = df.select_dtypes(include=['datetime64[ns]', 'datetime64']).columns.tolist()\\n\",\n",
    "    \"\\n\",\n",
    "    \"drop_cols = list(set(id_cols + date_cols + [TARGET, 'target']))\\n\",\n",
    "    \"\\n\",\n",
    "    \"feature_cols = [c for c in df.columns if c not in drop_cols]\\n\",\n",
    "    \"print(f'Features ({len(feature_cols)}): {feature_cols}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"X = df[feature_cols].copy()\\n\",\n",
    "    \"y = df['target'].copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"X_train, X_test, y_train, y_test = train_test_split(\\n\",\n",
    "    \"    X, y, test_size=TEST_SIZE, random_state=RANDOM_STATE, stratify=y\\n\",\n",
    "    \")\\n\",\n",
    "    \"print(f'Train: {X_train.shape[0]:,} | Test: {X_test.shape[0]:,}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Preprocessing\\n\",\n",
    "    \"\\n\",\n",
    "    \"Key design decisions to avoid data leakage:\\n\",\n",
    "    \"- **LabelEncoder** is fit on the combined unique values of train + test (so unseen categories in test don't cause errors), but both sets get the same encoding.\\n\",\n",
    "    \"- Any remaining date-like string columns are extracted and dropped.\\n\",\n",
    "    \"- Missing values are imputed using the **training median** only.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"def preprocess(X_tr, X_te):\\n\",\n",
    "    \"    \\\"\\\"\\\"Preprocess train and test sets without data leakage.\\\"\\\"\\\"\\n\",\n",
    "    \"    X_tr, X_te = X_tr.copy(), X_te.copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Handle any remaining date-like string columns\\n\",\n",
    "    \"    for col in list(X_tr.columns):  # list() avoids mutation-during-iteration\\n\",\n",
    "    \"        if X_tr[col].dtype == 'object':\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                dt_tr = pd.to_datetime(X_tr[col], errors='coerce')\\n\",\n",
    "    \"                if dt_tr.notna().mean() > 0.5:  # mostly valid dates\\n\",\n",
    "    \"                    dt_te = pd.to_datetime(X_te[col], errors='coerce')\\n\",\n",
    "    \"                    X_tr[f'{col}_dayofweek'] = dt_tr.dt.dayofweek\\n\",\n",
    "    \"                    X_tr[f'{col}_month'] = dt_tr.dt.month\\n\",\n",
    "    \"                    X_te[f'{col}_dayofweek'] = dt_te.dt.dayofweek\\n\",\n",
    "    \"                    X_te[f'{col}_month'] = dt_te.dt.month\\n\",\n",
    "    \"                    X_tr.drop(columns=[col], inplace=True)\\n\",\n",
    "    \"                    X_te.drop(columns=[col], inplace=True)\\n\",\n",
    "    \"                    continue\\n\",\n",
    "    \"            except Exception:\\n\",\n",
    "    \"                pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Encode categoricals — fit on combined unique values, apply to both\\n\",\n",
    "    \"    label_encoders = {}\\n\",\n",
    "    \"    cat_cols = X_tr.select_dtypes(include='object').columns.tolist()\\n\",\n",
    "    \"    for col in cat_cols:\\n\",\n",
    "    \"        le = LabelEncoder()\\n\",\n",
    "    \"        all_vals = pd.concat([X_tr[col], X_te[col]]).astype(str).unique()\\n\",\n",
    "    \"        le.fit(all_vals)\\n\",\n",
    "    \"        X_tr[col] = le.transform(X_tr[col].astype(str))\\n\",\n",
    "    \"        X_te[col] = le.transform(X_te[col].astype(str))\\n\",\n",
    "    \"        label_encoders[col] = le\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Align columns (safety check)\\n\",\n",
    "    \"    common = X_tr.columns.intersection(X_te.columns)\\n\",\n",
    "    \"    X_tr, X_te = X_tr[common], X_te[common]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Fill missing with training median\\n\",\n",
    "    \"    train_median = X_tr.median()\\n\",\n",
    "    \"    X_tr = X_tr.fillna(train_median)\\n\",\n",
    "    \"    X_te = X_te.fillna(train_median)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return X_tr, X_te\\n\",\n",
    "    \"\\n\",\n",
    "    \"X_train_p, X_test_p = preprocess(X_train, X_test)\\n\",\n",
    "    \"print(f'Preprocessed train shape: {X_train_p.shape}')\\n\",\n",
    "    \"print(f'Preprocessed test shape:  {X_test_p.shape}')\\n\",\n",
    "    \"print(f'Any nulls remaining: {X_train_p.isnull().any().any()}')\\n\",\n",
    "    \"X_train_p.head()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Final Feature Summary\\n\",\n",
    "    \"\\n\",\n",
    "    \"Key features after engineering:\\n\",\n",
    "    \"- `lead_time_days` — days between scheduling and appointment (strongest predictor)\\n\",\n",
    "    \"- `Age` — patient age\\n\",\n",
    "    \"- `SMS_received` — whether the patient received an SMS reminder\\n\",\n",
    "    \"- `Scholarship` — whether the patient is in a social welfare program\\n\",\n",
    "    \"- Health conditions: `Hipertension`, `Diabetes`, `Alcoholism`, `Handcap`\\n\",\n",
    "    \"- Calendar features: day-of-week, month, scheduling hour\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(f'Final features ({len(X_train_p.columns)}): {list(X_train_p.columns)}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Baseline Model\\n\",\n",
    "    \"\\n\",\n",
    "    \"Logistic Regression provides a simple baseline. On imbalanced data, we pay attention to **F1** and **PR-AUC**, not just accuracy.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"baseline = LogisticRegression(max_iter=1000, random_state=RANDOM_STATE)\\n\",\n",
    "    \"baseline.fit(X_train_p, y_train)\\n\",\n",
    "    \"y_pred_b = baseline.predict(X_test_p)\\n\",\n",
    "    \"y_prob_b = baseline.predict_proba(X_test_p)[:, 1]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print('=== Baseline: Logistic Regression ===')\\n\",\n",
    "    \"print(f'Accuracy:  {accuracy_score(y_test, y_pred_b):.4f}')\\n\",\n",
    "    \"print(f'F1:        {f1_score(y_test, y_pred_b):.4f}')\\n\",\n",
    "    \"print(f'ROC-AUC:   {roc_auc_score(y_test, y_prob_b):.4f}')\\n\",\n",
    "    \"print(f'PR-AUC:    {average_precision_score(y_test, y_prob_b):.4f}')\\n\",\n",
    "    \"print(classification_report(y_test, y_pred_b))\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## LazyPredict Benchmark\\n\",\n",
    "    \"\\n\",\n",
    "    \"LazyPredict fits ~30 classifiers with default hyperparameters in one call, giving us a quick leaderboard to identify promising model families.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"lazy = LazyClassifier(verbose=0, ignore_warnings=True)\\n\",\n",
    "    \"lazy_models, _ = lazy.fit(X_train_p, X_test_p, y_train, y_test)\\n\",\n",
    "    \"print('Top 15 models:')\\n\",\n",
    "    \"lazy_models.head(15)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"lazy_models['Accuracy'].head(15).plot(kind='barh', color='steelblue', edgecolor='black')\\n\",\n",
    "    \"plt.title('LazyPredict — Top Models by Accuracy')\\n\",\n",
    "    \"plt.xlabel('Accuracy')\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## FLAML AutoML Run\\n\",\n",
    "    \"\\n\",\n",
    "    \"FLAML performs intelligent hyperparameter search. We optimize for **F1** since accuracy is misleading on imbalanced data.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"automl = AutoML()\\n\",\n",
    "    \"automl.fit(X_train_p, y_train, task='classification', time_budget=FLAML_TIME_BUDGET,\\n\",\n",
    "    \"           metric='f1', verbose=0, seed=RANDOM_STATE)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f'Best estimator: {automl.best_estimator}')\\n\",\n",
    "    \"y_pred_fl = automl.predict(X_test_p)\\n\",\n",
    "    \"y_prob_fl = automl.predict_proba(X_test_p)[:, 1]\\n\",\n",
    "    \"print(f'F1:      {f1_score(y_test, y_pred_fl):.4f}')\\n\",\n",
    "    \"print(f'ROC-AUC: {roc_auc_score(y_test, y_prob_fl):.4f}')\\n\",\n",
    "    \"print(f'PR-AUC:  {average_precision_score(y_test, y_prob_fl):.4f}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Top 3 Model Selection\\n\",\n",
    "    \"\\n\",\n",
    "    \"We pick the top 2 model families from LazyPredict (that we can re-instantiate) plus the FLAML winner, then retrain and evaluate all three.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"MODEL_MAP = {\\n\",\n",
    "    \"    'RandomForestClassifier': RandomForestClassifier(n_estimators=200, random_state=RANDOM_STATE),\\n\",\n",
    "    \"    'GradientBoostingClassifier': GradientBoostingClassifier(n_estimators=200, random_state=RANDOM_STATE),\\n\",\n",
    "    \"    'ExtraTreesClassifier': ExtraTreesClassifier(n_estimators=200, random_state=RANDOM_STATE),\\n\",\n",
    "    \"    'LogisticRegression': LogisticRegression(max_iter=1000, random_state=RANDOM_STATE),\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"names, models = [], []\\n\",\n",
    "    \"for n in lazy_models.head(5).index:\\n\",\n",
    "    \"    if n in MODEL_MAP and len(names) < 2:\\n\",\n",
    "    \"        names.append(f'Lazy: {n}')\\n\",\n",
    "    \"        models.append(MODEL_MAP[n])\\n\",\n",
    "    \"\\n\",\n",
    "    \"names.append(f'FLAML: {automl.best_estimator}')\\n\",\n",
    "    \"models.append(automl.model.estimator if hasattr(automl.model, 'estimator') else automl.model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"while len(models) < 3:\\n\",\n",
    "    \"    names.append('Fallback: GradientBoosting')\\n\",\n",
    "    \"    models.append(GradientBoostingClassifier(n_estimators=200, random_state=RANDOM_STATE))\\n\",\n",
    "    \"\\n\",\n",
    "    \"print('Top 3 models selected:')\\n\",\n",
    "    \"for i, n in enumerate(names[:3], 1):\\n\",\n",
    "    \"    print(f'  {i}. {n}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Final Training and Evaluation of Top 3\\n\",\n",
    "    \"\\n\",\n",
    "    \"We train each model on the full training set and evaluate on the held-out test set with multiple metrics.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"results = []\\n\",\n",
    "    \"for name, model in zip(names[:3], models[:3]):\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        model.fit(X_train_p, y_train)\\n\",\n",
    "    \"    except Exception:\\n\",\n",
    "    \"        pass  # FLAML model is already fitted\\n\",\n",
    "    \"    y_pred = model.predict(X_test_p)\\n\",\n",
    "    \"    y_prob = model.predict_proba(X_test_p)[:, 1] if hasattr(model, 'predict_proba') else None\\n\",\n",
    "    \"    results.append({\\n\",\n",
    "    \"        'Model': name,\\n\",\n",
    "    \"        'Accuracy': accuracy_score(y_test, y_pred),\\n\",\n",
    "    \"        'Precision': precision_score(y_test, y_pred, zero_division=0),\\n\",\n",
    "    \"        'Recall': recall_score(y_test, y_pred, zero_division=0),\\n\",\n",
    "    \"        'F1': f1_score(y_test, y_pred, zero_division=0),\\n\",\n",
    "    \"        'ROC-AUC': roc_auc_score(y_test, y_prob) if y_prob is not None else np.nan,\\n\",\n",
    "    \"        'PR-AUC': average_precision_score(y_test, y_prob) if y_prob is not None else np.nan\\n\",\n",
    "    \"    })\\n\",\n",
    "    \"    print(f'\\\\n=== {name} ===')\\n\",\n",
    "    \"    print(classification_report(y_test, y_pred))\\n\",\n",
    "    \"\\n\",\n",
    "    \"results_df = pd.DataFrame(results)\\n\",\n",
    "    \"results_df\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### Confusion Matrices\\n\",\n",
    "    \"\\n\",\n",
    "    \"Confusion matrices reveal false positives vs false negatives. In healthcare, **false negatives** (predicting show but patient no-shows) waste clinic slots.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, axes = plt.subplots(1, 3, figsize=(18, 5))\\n\",\n",
    "    \"for i, (n, m) in enumerate(zip(names[:3], models[:3])):\\n\",\n",
    "    \"    cm = confusion_matrix(y_test, m.predict(X_test_p))\\n\",\n",
    "    \"    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[i])\\n\",\n",
    "    \"    axes[i].set_title(n.split(': ')[-1])\\n\",\n",
    "    \"    axes[i].set_xlabel('Predicted')\\n\",\n",
    "    \"    axes[i].set_ylabel('Actual')\\n\",\n",
    "    \"plt.suptitle('Confusion Matrices')\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### ROC Curves\\n\",\n",
    "    \"\\n\",\n",
    "    \"ROC curves show the trade-off between true positive rate and false positive rate at different classification thresholds.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"plt.figure(figsize=(8, 6))\\n\",\n",
    "    \"for name, model in zip(names[:3], models[:3]):\\n\",\n",
    "    \"    if hasattr(model, 'predict_proba'):\\n\",\n",
    "    \"        y_prob = model.predict_proba(X_test_p)[:, 1]\\n\",\n",
    "    \"        fpr, tpr, _ = roc_curve(y_test, y_prob)\\n\",\n",
    "    \"        auc_val = roc_auc_score(y_test, y_prob)\\n\",\n",
    "    \"        plt.plot(fpr, tpr, label=f'{name.split(\\\": \\\")[-1]} (AUC={auc_val:.3f})')\\n\",\n",
    "    \"plt.plot([0, 1], [0, 1], 'k--', alpha=0.5, label='Random')\\n\",\n",
    "    \"plt.xlabel('False Positive Rate')\\n\",\n",
    "    \"plt.ylabel('True Positive Rate')\\n\",\n",
    "    \"plt.title('ROC Curves')\\n\",\n",
    "    \"plt.legend()\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Error Analysis\\n\",\n",
    "    \"\\n\",\n",
    "    \"We compare the feature distributions of correctly vs incorrectly predicted samples to understand where the best model struggles.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"best_idx = results_df['F1'].idxmax()\\n\",\n",
    "    \"best_m = models[best_idx]\\n\",\n",
    "    \"best_name = names[best_idx]\\n\",\n",
    "    \"y_pred_best = best_m.predict(X_test_p)\\n\",\n",
    "    \"\\n\",\n",
    "    \"errors = X_test_p.copy()\\n\",\n",
    "    \"errors['y_true'] = y_test.values\\n\",\n",
    "    \"errors['y_pred'] = y_pred_best\\n\",\n",
    "    \"errors['correct'] = errors['y_true'] == errors['y_pred']\\n\",\n",
    "    \"\\n\",\n",
    "    \"n_errors = (~errors['correct']).sum()\\n\",\n",
    "    \"print(f'Best model: {best_name}')\\n\",\n",
    "    \"print(f'Errors: {n_errors} / {len(errors)} ({n_errors/len(errors):.1%})')\\n\",\n",
    "    \"print(f'\\\\nMean feature values — correct vs incorrect predictions:')\\n\",\n",
    "    \"errors.groupby('correct').mean(numeric_only=True)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Interpretation and Business Insights\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. **SMS reminders** have a measurable effect on attendance — patients who received SMS are less likely to no-show\\n\",\n",
    "    \"2. **Age** is a factor — younger patients tend to have higher no-show rates\\n\",\n",
    "    \"3. **Lead time** (days between scheduling and appointment) strongly affects attendance — longer lead times correlate with higher no-show rates\\n\",\n",
    "    \"4. **Neighbourhood effects** may capture socioeconomic factors influencing attendance\\n\",\n",
    "    \"5. **Same-day appointments** have near-zero no-show rates\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Recommendation**: Prioritize SMS reminders for younger patients with longer lead times. Consider follow-up reminders as the appointment approaches.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Limitations\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. Dataset is from a specific Brazilian city — results may not generalize to other healthcare systems\\n\",\n",
    "    \"2. Class imbalance (~20% no-show) makes accuracy misleading — F1 and PR-AUC are better metrics\\n\",\n",
    "    \"3. Missing contextual factors (weather, transport distance, illness severity)\\n\",\n",
    "    \"4. No temporal validation (we use random split, not time-based)\\n\",\n",
    "    \"5. Neighbourhood is high-cardinality and label-encoded — frequency or target encoding may be better\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## How to Improve This Project\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. Use **time-based split** to simulate real-world deployment (train on past, predict future)\\n\",\n",
    "    \"2. Add **SMOTE** or **class weights** for better handling of imbalance\\n\",\n",
    "    \"3. Engineer **distance/travel features** if geolocation data is available\\n\",\n",
    "    \"4. Use **SHAP** for model-agnostic feature importance\\n\",\n",
    "    \"5. Try **threshold optimization** — lowering the decision threshold can boost recall on the minority class\\n\",\n",
    "    \"6. Use **target encoding** or **frequency encoding** for high-cardinality categorical features like Neighbourhood\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Production Considerations\\n\",\n",
    "    \"\\n\",\n",
    "    \"- Deploy as a daily batch prediction to flag high-risk appointments\\n\",\n",
    "    \"- Integrate with clinic SMS systems for automated reminders\\n\",\n",
    "    \"- Monitor no-show rate drift over time (concept drift)\\n\",\n",
    "    \"- Audit for demographic fairness in predictions\\n\",\n",
    "    \"- Consider A/B testing reminder strategies based on predicted risk tiers\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Common Mistakes\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. **Using accuracy as primary metric** with imbalanced classes — a model that always predicts \\\"showed up\\\" gets ~80% accuracy but catches zero no-shows\\n\",\n",
    "    \"2. **Including patient ID as a feature** — the model memorizes patients instead of learning patterns\\n\",\n",
    "    \"3. **Not encoding the target correctly** — confusing `Yes`/`No` direction (Yes = missed, not Yes = showed up)\\n\",\n",
    "    \"4. **Data leakage from preprocessing** — fitting LabelEncoder on the full dataset before splitting leaks test-set information\\n\",\n",
    "    \"5. **Ignoring lead time** — the number of days between scheduling and appointment is often the strongest predictor, yet many beginners skip date feature engineering\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Mini Challenge / Exercises\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. **SMOTE experiment**: Apply SMOTE to the training set and compare F1 scores before and after\\n\",\n",
    "    \"2. **Threshold tuning**: Plot precision and recall vs threshold for the best model — find the threshold that maximizes F1\\n\",\n",
    "    \"3. **Time-based split**: Sort by `AppointmentDay` and use the last 20% as the test set — does performance change?\\n\",\n",
    "    \"4. **VotingClassifier**: Combine the top 3 models into a soft-voting ensemble — does it beat individual models?\\n\",\n",
    "    \"5. **Feature importance**: Use `model.feature_importances_` (for tree models) or SHAP to rank features\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Final Summary / Key Takeaways\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. Medical no-show prediction is a **class-imbalanced problem** requiring F1 and PR-AUC evaluation — not just accuracy\\n\",\n",
    "    \"2. **Lead time** (days between scheduling and appointment) is one of the strongest predictive features\\n\",\n",
    "    \"3. LazyPredict quickly identified strong model families; FLAML automated hyperparameter search\\n\",\n",
    "    \"4. SMS reminders and patient age are actionable predictive features\\n\",\n",
    "    \"5. Proper preprocessing (no data leakage, careful encoding) is critical for valid results\\n\",\n",
    "    \"6. The pipeline is adaptable to other healthcare scheduling systems with similar data\"\n",
    "   ]\n",
    "  }\n",
