    "    \"RANDOM_STATE = 42\\n\",\n",
    "    \"TEST_SIZE = 0.2\\n\",\n",
    "    \"BURNOUT_THRESHOLD = 0.5  # Burn Rate >= 0.5 → burned out (1)\\n\",\n",
    "    \"FLAML_TIME_BUDGET = 120  # seconds\\n\",\n",
