   "metadata": {},
   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"# Project 80 \\u2014 Local Fine-Tuning Evals Harness\\n\", \"\\n\", \"**Build evaluation notebooks for future fine-tuning runs \\u2014 locally.**\\n\", \"\\n\", \"| Component | Choice |\\n\", \"|-----------|--------|\\n\", \"| LLM | Ollama (qwen3:8b) |\\n\", \"| Eval | pandas + LLM-as-judge |\\n\", \"| Interface | Jupyter |\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 1 \\u00b7 What You Will Learn\\n\", \"\\n\", \"1. Build an **evaluation harness** for fine-tuned models\\n\", \"2. Define **test suites** with expected behaviors\\n\", \"3. Measure **accuracy, consistency, regression**\\n\", \"4. Compare **base vs fine-tuned** performance\\n\", \"5. Track **eval results over time**\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 2 \\u00b7 Why It Matters\\n\", \"\\n\", \"Fine-tuning without evaluation is flying blind.\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 3 \\u00b7 Setup\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"# !pip install -q langchain langchain-ollama pandas\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 4 \\u00b7 Imports\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"import json, time\\nimport pandas as pd\\nfrom datetime import datetime\\nfrom langchain_ollama import ChatOllama\\nfrom langchain_core.prompts import ChatPromptTemplate\\nfrom langchain_core.output_parsers import StrOutputParser\\n\\nMODEL = 'qwen3:8b'\\nllm = ChatOllama(model=MODEL, temperature=0.1)\\nprint(f'Model: {MODEL}')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 5 \\u00b7 Eval Test Suite\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"SUITE = {\\n    'classification': [\\n        {'input': 'App crashes on startup', 'expected': 'bug', 'type': 'exact'},\\n        {'input': 'Can you add dark mode?', 'expected': 'feature_request', 'type': 'exact'},\\n        {'input': 'Great product!', 'expected': 'praise', 'type': 'exact'},\\n    ],\\n    'extraction': [\\n        {'input': 'John, 34, engineer in Austin', 'fields': ['name','age','occupation'], 'type': 'fields'},\\n        {'input': 'TechCo, $5B revenue, 10K staff', 'fields': ['company_name','revenue'], 'type': 'fields'},\\n    ],\\n    'generation': [\\n        {'input': 'Explain what an API is in one sentence', 'criteria': 'accurate, concise', 'type': 'quality'},\\n        {'input': 'Write a meeting reschedule subject line', 'criteria': 'professional, clear', 'type': 'quality'},\\n    ],\\n}\\ntotal = sum(len(v) for v in SUITE.values())\\nprint(f'{total} tests across {len(SUITE)} categories')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 6 \\u00b7 Eval Functions\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"def eval_exact(llm_inst, tc, labels):\\n    p = ChatPromptTemplate.from_messages([('system',f'Classify: {labels}. Return ONLY label.'),('human','{input}')])\\n    raw = (p | llm_inst | StrOutputParser()).invoke({'input': tc['input']})\\n    return {'correct': tc['expected'] in raw.lower(), 'predicted': raw.strip()[:30]}\\n\\ndef eval_fields(llm_inst, tc):\\n    p = ChatPromptTemplate.from_messages([('system','Extract structured JSON.'),('human','{input}')])\\n    raw = (p | llm_inst | StrOutputParser()).invoke({'input': tc['input']})\\n    try:\\n        s, e = raw.find('{'), raw.rfind('}') + 1\\n        parsed = json.loads(raw[s:e]) if s >= 0 else {}\\n        found = sum(1 for f in tc['fields'] if any(f.lower() in k.lower() for k in parsed))\\n        return {'coverage': found/len(tc['fields'])}\\n    except: return {'coverage': 0}\\n\\ndef eval_quality(llm_inst, tc):\\n    resp = (ChatPromptTemplate.from_messages([('human','{input}')]) | llm_inst | StrOutputParser()).invoke({'input': tc['input']})\\n    jp = ChatPromptTemplate.from_messages([('system','Score 1-5. Criteria: {criteria}. Return JSON: {\\\"score\\\": N}'),('human','{resp}')])\\n    raw = (jp | llm | StrOutputParser()).invoke({'criteria': tc['criteria'], 'resp': resp})\\n    try:\\n        s, e = raw.find('{'), raw.rfind('}') + 1\\n        return {'score': json.loads(raw[s:e]).get('score',3)/5.0}\\n    except: return {'score': 0.6}\\n\\nprint('Eval functions ready.')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 7 \\u00b7 Run Evaluation\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"labels = 'bug,feature_request,praise,complaint'\\nresults = []\\nfor cat, tests in SUITE.items():\\n    print(f'\\\\n{cat}:')\\n    for tc in tests:\\n        if tc['type'] == 'exact':\\n            r = eval_exact(llm, tc, labels)\\n            results.append({'cat': cat, 'input': tc['input'][:35], 'metric': 'accuracy', 'value': 1.0 if r['correct'] else 0.0})\\n            print(f'  [{\\\"OK\\\" if r[\\\"correct\\\"] else \\\"XX\\\"}] {tc[\\\"input\\\"][:35]}')\\n        elif tc['type'] == 'fields':\\n            r = eval_fields(llm, tc)\\n            results.append({'cat': cat, 'input': tc['input'][:35], 'metric': 'coverage', 'value': r['coverage']})\\n            print(f'  [COV={r[\\\"coverage\\\"]:.0%}] {tc[\\\"input\\\"][:35]}')\\n        elif tc['type'] == 'quality':\\n            r = eval_quality(llm, tc)\\n            results.append({'cat': cat, 'input': tc['input'][:35], 'metric': 'quality', 'value': r['score']})\\n            print(f'  [Q={r[\\\"score\\\"]:.0%}] {tc[\\\"input\\\"][:35]}')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 8 \\u00b7 Results\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"df = pd.DataFrame(results)\\nprint('BY CATEGORY:', df.groupby('cat')['value'].mean().round(3).to_string(), sep='\\\\n')\\nprint(f'\\\\nOverall: {df[\\\"value\\\"].mean():.1%}')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 9 \\u00b7 Save\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"rec = {'model': MODEL, 'time': datetime.now().isoformat(),\\n       'overall': round(df['value'].mean(), 3), 'by_cat': df.groupby('cat')['value'].mean().round(3).to_dict(),\\n       'results': results}\\nwith open('eval_results.json','w') as f: json.dump(rec, f, indent=2, default=str)\\nprint('Saved.')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 10 \\u00b7 Key Takeaways\\n\", \"\\n\", \"- Eval harnesses measure model behavior systematically\\n\", \"- Multiple eval types catch different issues\\n\", \"- Save results with timestamps for tracking over time\\n\", \"- Run same harness before and after fine-tuning to measure gains\"]}\n",
    " ],\n",
