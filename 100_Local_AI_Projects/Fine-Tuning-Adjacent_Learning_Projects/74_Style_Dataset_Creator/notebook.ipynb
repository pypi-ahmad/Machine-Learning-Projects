   "metadata": {},
   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"# Project 74 \\u2014 Style Dataset Creator\\n\", \"\\n\", \"**Build a tone/style dataset from examples for future fine-tuning.**\\n\", \"\\n\", \"| Component | Choice |\\n\", \"|-----------|--------|\\n\", \"| LLM | Ollama (qwen3:8b) |\\n\", \"| Data | pandas |\\n\", \"| Interface | Jupyter |\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 1 \\u00b7 What You Will Learn\\n\", \"\\n\", \"1. Define and capture **writing styles** programmatically\\n\", \"2. Generate **style-consistent examples** with LLMs\\n\", \"3. Build a **style transfer dataset** for fine-tuning\\n\", \"4. Validate **style adherence** with automated checks\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 2 \\u00b7 Why It Matters\\n\", \"\\n\", \"Brand voice and tone consistency require style-specific fine-tuning data.\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 3 \\u00b7 Setup\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"# !pip install -q langchain langchain-ollama pandas\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 4 \\u00b7 Imports\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"import json\\nimport pandas as pd\\nfrom langchain_ollama import ChatOllama\\nfrom langchain_core.prompts import ChatPromptTemplate\\nfrom langchain_core.output_parsers import StrOutputParser\\n\\nMODEL = 'qwen3:8b'\\nllm = ChatOllama(model=MODEL, temperature=0.7)\\nprint(f'LLM ready: {MODEL}')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 5 \\u00b7 Define Styles and Topics\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"STYLES = [\\n    {'name': 'formal_technical', 'desc': 'Precise, third-person, no contractions, structured.',\\n     'example': 'The function accepts two parameters and returns a processed list.'},\\n    {'name': 'casual_friendly', 'desc': 'Casual, contractions, simple words, direct address.',\\n     'example': \\\"Hey! Just pass in a name and number, and you'll get results back.\\\"},\\n    {'name': 'executive_brief', 'desc': 'Concise, action-oriented, impact and decisions.',\\n     'example': 'Key finding: latency reduced 40%. Recommendation: proceed Phase 2.'},\\n]\\nTOPICS = ['Explain REST APIs', 'Benefits of cloud computing', 'What ML does', 'Handling customer complaints']\\nprint(f'{len(STYLES)} styles, {len(TOPICS)} topics')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 6 \\u00b7 Generate Style Examples\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"prompt = ChatPromptTemplate.from_messages([\\n    ('system', 'Write in this style: {desc}\\\\nExample: {example}\\\\nKeep to 2-3 sentences.'),\\n    ('human', '{topic}'),\\n])\\nchain = prompt | llm | StrOutputParser()\\n\\ndataset = []\\nfor style in STYLES:\\n    print(f'Style: {style[\\\"name\\\"]}')\\n    for topic in TOPICS:\\n        resp = chain.invoke({'desc': style['desc'], 'example': style['example'], 'topic': topic})\\n        dataset.append({'topic': topic, 'style': style['name'], 'text': resp,\\n                        'instruction': f'Write about \\\"{topic}\\\" in {style[\\\"name\\\"]} style.'})\\n        print(f'  {topic[:30]}: {resp[:50]}...')\\nprint(f'\\\\n{len(dataset)} examples')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 7 \\u00b7 Validate and Export\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"val_prompt = ChatPromptTemplate.from_messages([\\n    ('system', 'Rate style match 1-5. Return JSON: {\\\"score\\\": N}'),\\n    ('human', 'Style: {style} ({desc})\\\\nText: {text}'),\\n])\\nval_chain = val_prompt | ChatOllama(model=MODEL, temperature=0.1) | StrOutputParser()\\n\\nfor e in dataset:\\n    s_info = next(s for s in STYLES if s['name'] == e['style'])\\n    raw = val_chain.invoke({'style': e['style'], 'desc': s_info['desc'], 'text': e['text']})\\n    try:\\n        s, end = raw.find('{'), raw.rfind('}') + 1\\n        e['score'] = json.loads(raw[s:end]).get('score', 3) if s >= 0 else 3\\n    except: e['score'] = 3\\n\\ndf = pd.DataFrame(dataset)\\nprint('Style scores:', df.groupby('style')['score'].mean().round(2).to_string(), sep='\\\\n')\\n\\nwith open('style_dataset.jsonl', 'w', encoding='utf-8') as f:\\n    for e in dataset:\\n        f.write(json.dumps({'instruction': e['instruction'], 'output': e['text']}) + '\\\\n')\\nprint(f'Exported {len(dataset)} pairs')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 8 \\u00b7 Key Takeaways\\n\", \"\\n\", \"- Style datasets teach models brand voice\\n\", \"- Examples should cover diverse topics per style\\n\", \"- Validation ensures adherence to target style\\n\", \"- Instruction format: topic + style \\u2192 styled text\"]}\n",
    " ],\n",
