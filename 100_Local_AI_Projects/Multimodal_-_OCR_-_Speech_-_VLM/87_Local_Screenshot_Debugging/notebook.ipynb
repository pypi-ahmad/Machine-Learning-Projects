 "cells": [
  {
   "metadata": {},
   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Project 87 \\u2014 Local Screenshot Debugging Assistant\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Explain UI screenshots and identify likely issues \\u2014 locally.**\\n\",\n",
    "    \"\\n\",\n",
    "    \"| Component | Choice |\\n\",\n",
    "    \"|-----------|--------|\\n\",\n",
    "    \"| VLM | Ollama (minicpm-v / llava) |\\n\",\n",
    "    \"| Fallback | Text-based error analysis |\\n\",\n",
    "    \"| Interface | Jupyter |\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1 \\u00b7 What You Will Learn\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. Use a **local VLM** to analyze UI screenshots\\n\",\n",
    "    \"2. Identify **error patterns** from visual cues\\n\",\n",
    "    \"3. Generate **debugging suggestions** from screenshots\\n\",\n",
    "    \"4. Build a **text fallback** for environments without VLM\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2 \\u00b7 Setup\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# !pip install -q langchain langchain-ollama Pillow\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3 \\u00b7 Imports\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import json, base64\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"from PIL import Image, ImageDraw\\n\",\n",
    "    \"from langchain_ollama import ChatOllama\\n\",\n",
    "    \"from langchain_core.prompts import ChatPromptTemplate\\n\",\n",
    "    \"from langchain_core.output_parsers import StrOutputParser\\n\",\n",
    "    \"from langchain_core.messages import HumanMessage\\n\",\n",
    "    \"\\n\",\n",
    "    \"TEXT_MODEL = 'qwen3:8b'\\n\",\n",
    "    \"VLM_MODEL = 'minicpm-v'\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    vlm = ChatOllama(model=VLM_MODEL, temperature=0.3)\\n\",\n",
    "    \"    vlm.invoke('test')\\n\",\n",
    "    \"    USE_VLM = True\\n\",\n",
    "    \"    print(f'VLM: {VLM_MODEL}')\\n\",\n",
    "    \"except:\\n\",\n",
    "    \"    USE_VLM = False\\n\",\n",
    "    \"    vlm = ChatOllama(model=TEXT_MODEL, temperature=0.3)\\n\",\n",
    "    \"    print(f'Text fallback: {TEXT_MODEL}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4 \\u00b7 Create Simulated Screenshots\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"Path('screenshots').mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def make_screenshot(text, filename, bg='white'):\\n\",\n",
    "    \"    img = Image.new('RGB', (500, 350), bg)\\n\",\n",
    "    \"    draw = ImageDraw.Draw(img)\\n\",\n",
    "    \"    draw.text((20, 20), text, fill='black')\\n\",\n",
    "    \"    # Add a red error box\\n\",\n",
    "    \"    draw.rectangle([15, 150, 485, 250], outline='red', width=3)\\n\",\n",
    "    \"    draw.text((25, 160), 'ERROR', fill='red')\\n\",\n",
    "    \"    img.save(filename)\\n\",\n",
    "    \"    return filename\\n\",\n",
    "    \"\\n\",\n",
    "    \"screenshots = [\\n\",\n",
    "    \"    {'path': make_screenshot('Login Page\\\\nEmail: user@test.com\\\\nPassword: ****\\\\n\\\\n[ERROR] Invalid credentials\\\\nPlease try again', 'screenshots/login_error.png', '#f5f5f5'),\\n\",\n",
    "    \"     'desc': 'Login page showing Invalid credentials error after form submission'},\\n\",\n",
    "    \"    {'path': make_screenshot('Dashboard\\\\nLoading data...\\\\n\\\\n[ERROR] 503 Service Unavailable\\\\nBackend server not responding', 'screenshots/503_error.png', '#f5f5f5'),\\n\",\n",
    "    \"     'desc': 'Dashboard showing 503 Service Unavailable error'},\\n\",\n",
    "    \"    {'path': make_screenshot('Settings > Profile\\\\nName: John Doe\\\\nEmail: (empty)\\\\n\\\\n[ERROR] Required field missing\\\\nEmail address is required', 'screenshots/form_error.png', '#f5f5f5'),\\n\",\n",
    "    \"     'desc': 'Settings form showing required field validation error for email'},\\n\",\n",
    "    \"]\\n\",\n",
    "    \"print(f'Created {len(screenshots)} screenshots')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5 \\u00b7 Analyze Screenshots\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"debug_prompt_text = ChatPromptTemplate.from_messages([\\n\",\n",
    "    \"    ('system', 'You are a UI debugging assistant. Given a screenshot description, identify the issue and suggest fixes.'),\\n\",\n",
    "    \"    ('human', 'Screenshot: {desc}\\\\nWhat is the issue and how to fix it?'),\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"for ss in screenshots:\\n\",\n",
    "    \"    print(f'\\\\n--- {Path(ss[\\\"path\\\"]).name} ---')\\n\",\n",
    "    \"    if USE_VLM:\\n\",\n",
    "    \"        with open(ss['path'], 'rb') as f:\\n\",\n",
    "    \"            b64 = base64.b64encode(f.read()).decode()\\n\",\n",
    "    \"        msg = HumanMessage(content=[\\n\",\n",
    "    \"            {'type': 'text', 'text': 'What error is shown? What is the likely cause and fix?'},\\n\",\n",
    "    \"            {'type': 'image_url', 'image_url': f'data:image/png;base64,{b64}'},\\n\",\n",
    "    \"        ])\\n\",\n",
    "    \"        analysis = vlm.invoke([msg]).content\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        analysis = (debug_prompt_text | vlm | StrOutputParser()).invoke({'desc': ss['desc']})\\n\",\n",
    "    \"    print(analysis[:300])\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6 \\u00b7 Export\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"with open('debug_results.json', 'w') as f:\\n\",\n",
    "    \"    json.dump([{'screenshot': s['path'], 'desc': s['desc']} for s in screenshots], f, indent=2)\\n\",\n",
    "    \"print('Saved.')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7 \\u00b7 Key Takeaways\\n\",\n",
    "    \"\\n\",\n",
    "    \"- Local VLMs can analyze UI screenshots for errors\\n\",\n",
    "    \"- Text fallback enables learning without VLM hardware\\n\",\n",
    "    \"- Useful for automated QA, bug triage, and support workflows\\n\",\n",
    "    \"- Production: integrate with screenshot capture tools\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
