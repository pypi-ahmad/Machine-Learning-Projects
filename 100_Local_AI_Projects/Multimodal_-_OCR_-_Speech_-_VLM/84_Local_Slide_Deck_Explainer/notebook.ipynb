 "cells": [
  {
   "metadata": {},
   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Project 84 \\u2014 Local Slide Deck Explainer\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Summarize PPT/PDF slides and generate speaking notes \\u2014 locally.**\\n\",\n",
    "    \"\\n\",\n",
    "    \"| Component | Choice |\\n\",\n",
    "    \"|-----------|--------|\\n\",\n",
    "    \"| LLM | Ollama (qwen3:8b) |\\n\",\n",
    "    \"| Input | Simulated slide text |\\n\",\n",
    "    \"| Interface | Jupyter |\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1 \\u00b7 What You Will Learn\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. Extract and process **slide content** from presentations\\n\",\n",
    "    \"2. Generate **slide-by-slide summaries**\\n\",\n",
    "    \"3. Create **speaker notes** for each slide\\n\",\n",
    "    \"4. Build a **full presentation summary**\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2 \\u00b7 Why It Matters\\n\",\n",
    "    \"\\n\",\n",
    "    \"Quickly understanding a slide deck without reading every slide saves time\\n\",\n",
    "    \"for meeting prep, review, and presentation coaching.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3 \\u00b7 Setup\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# !pip install -q langchain langchain-ollama\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4 \\u00b7 Imports\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import json\\n\",\n",
    "    \"from langchain_ollama import ChatOllama\\n\",\n",
    "    \"from langchain_core.prompts import ChatPromptTemplate\\n\",\n",
    "    \"from langchain_core.output_parsers import StrOutputParser\\n\",\n",
    "    \"\\n\",\n",
    "    \"MODEL = 'qwen3:8b'\\n\",\n",
    "    \"llm = ChatOllama(model=MODEL, temperature=0.3)\\n\",\n",
    "    \"print(f'LLM ready: {MODEL}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5 \\u00b7 Sample Slide Deck\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"SLIDES = [\\n\",\n",
    "    \"    {'slide': 1, 'title': 'Q4 2024 Results', 'content': 'Revenue: $2.3M (+15%)\\\\nCustomers: 450 (+12%)\\\\nChurn: 2.1% (improved)\\\\nNPS: 72'},\\n\",\n",
    "    \"    {'slide': 2, 'title': 'Product Updates', 'content': 'Launched: API v3, Mobile App 2.0\\\\nBeta: AI Assistant feature\\\\nRetired: Legacy dashboard\\\\n500+ bug fixes'},\\n\",\n",
    "    \"    {'slide': 3, 'title': 'Customer Wins', 'content': 'GlobalCorp: $500K ARR enterprise deal\\\\nTechStart: 200-seat expansion\\\\nMedCo: Healthcare vertical entry\\\\n3 case studies published'},\\n\",\n",
    "    \"    {'slide': 4, 'title': 'Challenges', 'content': 'Mid-market competition increasing\\\\nEngineering hiring: 3 open roles\\\\nInfra costs up 20%\\\\nCustomer onboarding taking 45 days avg'},\\n\",\n",
    "    \"    {'slide': 5, 'title': 'Q1 2025 Plan', 'content': 'Focus: Product-led growth\\\\nTarget: 520 customers\\\\nLaunch: Self-serve tier\\\\nHire: 5 engineers, 2 sales\\\\nBudget: $1.8M'},\\n\",\n",
    "    \"]\\n\",\n",
    "    \"print(f'{len(SLIDES)} slides')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6 \\u00b7 Generate Slide Summaries and Speaker Notes\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"summary_prompt = ChatPromptTemplate.from_messages([\\n\",\n",
    "    \"    ('system', 'For the slide, provide:\\\\n1. A 1-sentence summary\\\\n2. 2-3 bullet speaker notes (what to say when presenting)\\\\nReturn JSON: {\\\"summary\\\": \\\"...\\\", \\\"notes\\\": [\\\"...\\\", \\\"...\\\"]}'),\\n\",\n",
    "    \"    ('human', 'Slide {num}: {title}\\\\n{content}'),\\n\",\n",
    "    \"])\\n\",\n",
    "    \"chain = summary_prompt | llm | StrOutputParser()\\n\",\n",
    "    \"\\n\",\n",
    "    \"results = []\\n\",\n",
    "    \"for slide in SLIDES:\\n\",\n",
    "    \"    raw = chain.invoke({'num': slide['slide'], 'title': slide['title'], 'content': slide['content']})\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        s, e = raw.find('{'), raw.rfind('}') + 1\\n\",\n",
    "    \"        parsed = json.loads(raw[s:e]) if s >= 0 else {}\\n\",\n",
    "    \"        results.append({'slide': slide['slide'], 'title': slide['title'], **parsed})\\n\",\n",
    "    \"        print(f'Slide {slide[\\\"slide\\\"]}: {parsed.get(\\\"summary\\\", \\\"?\\\")[:80]}')\\n\",\n",
    "    \"    except:\\n\",\n",
    "    \"        results.append({'slide': slide['slide'], 'title': slide['title'], 'summary': 'Parse error', 'notes': []})\\n\",\n",
    "    \"        print(f'Slide {slide[\\\"slide\\\"]}: Parse error')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7 \\u00b7 Full Deck Summary\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"all_summaries = '\\\\n'.join([f'Slide {r[\\\"slide\\\"]} ({r[\\\"title\\\"]}): {r.get(\\\"summary\\\",\\\"\\\")}' for r in results])\\n\",\n",
    "    \"\\n\",\n",
    "    \"deck_prompt = ChatPromptTemplate.from_messages([\\n\",\n",
    "    \"    ('system', 'Write a 3-4 sentence executive summary of this presentation.'),\\n\",\n",
    "    \"    ('human', '{summaries}'),\\n\",\n",
    "    \"])\\n\",\n",
    "    \"deck_chain = deck_prompt | llm | StrOutputParser()\\n\",\n",
    "    \"\\n\",\n",
    "    \"exec_summary = deck_chain.invoke({'summaries': all_summaries})\\n\",\n",
    "    \"print('EXECUTIVE SUMMARY:')\\n\",\n",
    "    \"print(exec_summary)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 8 \\u00b7 Export\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"output = {'slides': results, 'executive_summary': exec_summary}\\n\",\n",
    "    \"with open('slide_notes.json', 'w') as f: json.dump(output, f, indent=2, default=str)\\n\",\n",
    "    \"print('Saved.')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 9 \\u00b7 Key Takeaways\\n\",\n",
    "    \"\\n\",\n",
    "    \"- LLM generates per-slide summaries and speaker notes\\n\",\n",
    "    \"- Executive summary gives quick deck overview\\n\",\n",
    "    \"- Production: extract text from PPTX/PDF with python-pptx or PyMuPDF\\n\",\n",
    "    \"- Speaker notes help presenters prepare quickly\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
