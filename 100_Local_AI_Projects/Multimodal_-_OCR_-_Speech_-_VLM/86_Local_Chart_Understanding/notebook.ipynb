   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"# Project 86 \\u2014 Local Chart Understanding Notebook\\n\", \"\\n\", \"**Explain chart images and trends using a local VLM.**\\n\", \"\\n\", \"| Component | Choice |\\n\", \"|-----------|--------|\\n\", \"| VLM | Ollama (minicpm-v / llava) |\\n\", \"| Fallback | Text-based chart description |\\n\", \"| Charts | matplotlib |\\n\", \"| Interface | Jupyter |\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 1 \\u00b7 What You Will Learn\\n\", \"\\n\", \"1. Generate **chart images** programmatically\\n\", \"2. Use a **local VLM** to explain chart contents\\n\", \"3. Extract **trends and insights** from visualizations\\n\", \"4. Compare **VLM vs text-only** analysis\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 2 \\u00b7 Setup\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"# !pip install -q langchain langchain-ollama matplotlib\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 3 \\u00b7 Imports\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"import json, base64\\nimport matplotlib\\nmatplotlib.use('Agg')\\nimport matplotlib.pyplot as plt\\nfrom pathlib import Path\\nfrom langchain_ollama import ChatOllama\\nfrom langchain_core.prompts import ChatPromptTemplate\\nfrom langchain_core.output_parsers import StrOutputParser\\nfrom langchain_core.messages import HumanMessage\\n\\nTEXT_MODEL = 'qwen3:8b'\\nVLM_MODEL = 'minicpm-v'\\ntry:\\n    vlm = ChatOllama(model=VLM_MODEL, temperature=0.3)\\n    vlm.invoke('test')\\n    USE_VLM = True\\n    print(f'VLM: {VLM_MODEL}')\\nexcept:\\n    USE_VLM = False\\n    vlm = ChatOllama(model=TEXT_MODEL, temperature=0.3)\\n    print(f'Text fallback: {TEXT_MODEL}')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 4 \\u00b7 Generate Sample Charts\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"Path('charts').mkdir(exist_ok=True)\\n\\n# Chart 1: Revenue trend\\nmonths = ['Jan','Feb','Mar','Apr','May','Jun']\\nrev = [1.2, 1.4, 1.3, 1.7, 1.9, 2.3]\\nfig, ax = plt.subplots(figsize=(6,4))\\nax.plot(months, rev, 'b-o', linewidth=2)\\nax.set_title('Monthly Revenue ($M)')\\nax.set_ylabel('Revenue')\\nfig.savefig('charts/revenue.png', dpi=100, bbox_inches='tight')\\nplt.close()\\n\\n# Chart 2: Category distribution\\ncats = ['SaaS','Consulting','Support','Training']\\nvals = [45, 25, 20, 10]\\nfig, ax = plt.subplots(figsize=(6,4))\\nax.bar(cats, vals, color=['#4285f4','#ea4335','#fbbc04','#34a853'])\\nax.set_title('Revenue by Category (%)')\\nfig.savefig('charts/categories.png', dpi=100, bbox_inches='tight')\\nplt.close()\\n\\ncharts = [\\n    {'path': 'charts/revenue.png', 'data_desc': f'Line chart: months {months}, values {rev}'},\\n    {'path': 'charts/categories.png', 'data_desc': f'Bar chart: {dict(zip(cats,vals))}'},\\n]\\nprint(f'Created {len(charts)} charts')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 5 \\u00b7 Analyze Charts\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"def analyze_chart(chart, prompt='Describe this chart. What trends or insights do you see?'):\\n    if USE_VLM:\\n        with open(chart['path'], 'rb') as f:\\n            b64 = base64.b64encode(f.read()).decode()\\n        msg = HumanMessage(content=[\\n            {'type': 'text', 'text': prompt},\\n            {'type': 'image_url', 'image_url': f'data:image/png;base64,{b64}'},\\n        ])\\n        return vlm.invoke([msg]).content\\n    else:\\n        p = ChatPromptTemplate.from_messages([\\n            ('system', 'You are analyzing a chart. Describe trends and insights.'),\\n            ('human', 'Chart data: {data}'),\\n        ])\\n        return (p | vlm | StrOutputParser()).invoke({'data': chart['data_desc']})\\n\\nfor chart in charts:\\n    print(f'\\\\n--- {Path(chart[\\\"path\\\"]).name} ---')\\n    analysis = analyze_chart(chart)\\n    print(analysis[:300])\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 6 \\u00b7 Export\"]},\n",
    "  {\"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"results = []\\nfor chart in charts:\\n    a = analyze_chart(chart)\\n    results.append({'chart': chart['path'], 'analysis': a})\\nwith open('chart_analysis.json', 'w') as f: json.dump(results, f, indent=2, default=str)\\nprint('Saved.')\"]},\n",
    "  {\"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"## 7 \\u00b7 Key Takeaways\\n\", \"\\n\", \"- Local VLMs can interpret chart images and extract trends\\n\", \"- Programmatic chart generation enables controlled testing\\n\", \"- Text fallback uses underlying data when VLM unavailable\\n\", \"- Useful for automated report summarization\"]}\n",
    " ],\n",
