 "cells": [
  {
   "metadata": {},
   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Project 10 — Local Code Explainer\\n\",\n",
    "    \"\\n\",\n",
    "    \"## Explain Code Snippets and Detect Issues\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Goal:** Build a local code analysis assistant: explain code, detect bugs,\\n\",\n",
    "    \"suggest fixes, and analyze complexity — all with Ollama.\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Stack:** Ollama · LangChain · Jupyter\\n\",\n",
    "    \"\\n\",\n",
    "    \"### What You'll Learn\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. Code explanation generation\\n\",\n",
    "    \"2. Bug detection and code review\\n\",\n",
    "    \"3. Improvement suggestions\\n\",\n",
    "    \"4. Structured analysis\\n\",\n",
    "    \"5. Complexity analysis\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# !pip install -q langchain langchain-ollama pydantic\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Step 1 — Configure LLM\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import requests\\n\",\n",
    "    \"from langchain_ollama import ChatOllama\\n\",\n",
    "    \"from langchain_core.prompts import ChatPromptTemplate\\n\",\n",
    "    \"from langchain_core.output_parsers import StrOutputParser\\n\",\n",
    "    \"from pydantic import BaseModel, Field\\n\",\n",
    "    \"\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    r = requests.get(\\\"http://localhost:11434/api/tags\\\", timeout=5)\\n\",\n",
    "    \"    print(f\\\"Ollama running — {len(r.json().get('models', []))} models\\\")\\n\",\n",
    "    \"except: print(\\\"Start Ollama first!\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"llm = ChatOllama(model=\\\"qwen3:8b\\\", temperature=0.1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"code_samples = {\\n\",\n",
    "    \"    \\\"binary_search\\\": \\\"\\\"\\\"\\n\",\n",
    "    \"def binary_search(arr, target):\\n\",\n",
    "    \"    left, right = 0, len(arr) - 1\\n\",\n",
    "    \"    while left <= right:\\n\",\n",
    "    \"        mid = (left + right) // 2\\n\",\n",
    "    \"        if arr[mid] == target:\\n\",\n",
    "    \"            return mid\\n\",\n",
    "    \"        elif arr[mid] < target:\\n\",\n",
    "    \"            left = mid + 1\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            right = mid - 1\\n\",\n",
    "    \"    return -1\\n\",\n",
    "    \"\\\"\\\"\\\",\\n\",\n",
    "    \"    \\\"buggy_function\\\": \\\"\\\"\\\"\\n\",\n",
    "    \"def calculate_average(numbers):\\n\",\n",
    "    \"    total = 0\\n\",\n",
    "    \"    for i in range(len(numbers)):\\n\",\n",
    "    \"        total += numbers[i]\\n\",\n",
    "    \"    average = total / len(numbers)\\n\",\n",
    "    \"    return average\\n\",\n",
    "    \"\\n\",\n",
    "    \"result = calculate_average([])\\n\",\n",
    "    \"\\\"\\\"\\\",\\n\",\n",
    "    \"    \\\"complex_decorator\\\": \\\"\\\"\\\"\\n\",\n",
    "    \"import functools\\n\",\n",
    "    \"import time\\n\",\n",
    "    \"\\n\",\n",
    "    \"def retry(max_attempts=3, delay=1):\\n\",\n",
    "    \"    def decorator(func):\\n\",\n",
    "    \"        @functools.wraps(func)\\n\",\n",
    "    \"        def wrapper(*args, **kwargs):\\n\",\n",
    "    \"            for attempt in range(max_attempts):\\n\",\n",
    "    \"                try:\\n\",\n",
    "    \"                    return func(*args, **kwargs)\\n\",\n",
    "    \"                except Exception as e:\\n\",\n",
    "    \"                    if attempt == max_attempts - 1:\\n\",\n",
    "    \"                        raise\\n\",\n",
    "    \"                    time.sleep(delay * (2 ** attempt))\\n\",\n",
    "    \"            return None\\n\",\n",
    "    \"        return wrapper\\n\",\n",
    "    \"    return decorator\\n\",\n",
    "    \"\\\"\\\"\\\",\\n\",\n",
    "    \"}\\n\",\n",
    "    \"print(f\\\"Loaded {len(code_samples)} code samples\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Step 2 — Line-by-Line Explanation\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"explain_prompt = ChatPromptTemplate.from_messages([\\n\",\n",
    "    \"    (\\\"system\\\", \\\"\\\"\\\"You are a patient code tutor. Explain code line by line:\\n\",\n",
    "    \"- Explain what each line does in plain English\\n\",\n",
    "    \"- Note the algorithm or pattern being used\\n\",\n",
    "    \"- Explain time/space complexity\\n\",\n",
    "    \"- Use analogies for complex concepts\\n\",\n",
    "    \"- Target audience: intermediate Python developer\\\"\\\"\\\"),\\n\",\n",
    "    \"    (\\\"human\\\", \\\"Explain this code line by line:\\\\n```python\\\\n{code}\\\\n```\\\")\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"explain_chain = explain_prompt | llm | StrOutputParser()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for name, sample in code_samples.items():\\n\",\n",
    "    \"    print(f\\\"\\\\n{'='*60}\\\")\\n\",\n",
    "    \"    print(f\\\"Code: {name}\\\")\\n\",\n",
    "    \"    print('='*60)\\n\",\n",
    "    \"    explanation = explain_chain.invoke({\\\"code\\\": sample})\\n\",\n",
    "    \"    print(explanation)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Step 3 — Bug Detection\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"class Bug(BaseModel):\\n\",\n",
    "    \"    line_number: int = Field(description=\\\"Approximate line number\\\")\\n\",\n",
    "    \"    severity: str = Field(description=\\\"critical, warning, info\\\")\\n\",\n",
    "    \"    description: str\\n\",\n",
    "    \"    fix_suggestion: str\\n\",\n",
    "    \"\\n\",\n",
    "    \"class CodeReview(BaseModel):\\n\",\n",
    "    \"    bugs: list[Bug]\\n\",\n",
    "    \"    overall_quality: int = Field(description=\\\"1-10 code quality score\\\")\\n\",\n",
    "    \"    improvements: list[str]\\n\",\n",
    "    \"\\n\",\n",
    "    \"reviewer = llm.with_structured_output(CodeReview)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for name, sample in code_samples.items():\\n\",\n",
    "    \"    print(f\\\"\\\\nReviewing: {name}\\\")\\n\",\n",
    "    \"    review = reviewer.invoke(f\\\"Review this code for bugs and issues:\\\\n```python\\\\n{sample}\\\\n```\\\")\\n\",\n",
    "    \"    print(f\\\"  Quality: {review.overall_quality}/10\\\")\\n\",\n",
    "    \"    for bug in review.bugs:\\n\",\n",
    "    \"        print(f\\\"  [{bug.severity}] Line ~{bug.line_number}: {bug.description}\\\")\\n\",\n",
    "    \"        print(f\\\"    Fix: {bug.fix_suggestion}\\\")\\n\",\n",
    "    \"    for imp in review.improvements:\\n\",\n",
    "    \"        print(f\\\"  Suggestion: {imp}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Step 4 — Code Refactoring Suggestions\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"refactor_prompt = ChatPromptTemplate.from_messages([\\n\",\n",
    "    \"    (\\\"system\\\", \\\"\\\"\\\"Suggest how to refactor this code. Provide:\\n\",\n",
    "    \"1. The refactored code\\n\",\n",
    "    \"2. What changed and why\\n\",\n",
    "    \"3. Any Pythonic improvements (list comprehensions, generators, etc.)\\n\",\n",
    "    \"4. Error handling additions needed\\\"\\\"\\\"),\\n\",\n",
    "    \"    (\\\"human\\\", \\\"Refactor this code:\\\\n```python\\\\n{code}\\\\n```\\\")\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"refactor_chain = refactor_prompt | llm | StrOutputParser()\\n\",\n",
    "    \"print(\\\"Refactoring suggestions for 'buggy_function':\\\")\\n\",\n",
    "    \"result = refactor_chain.invoke({\\\"code\\\": code_samples[\\\"buggy_function\\\"]})\\n\",\n",
    "    \"print(result)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Step 5 — Complexity Analysis\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"complexity_prompt = ChatPromptTemplate.from_messages([\\n\",\n",
    "    \"    (\\\"system\\\", \\\"\\\"\\\"Analyze the time and space complexity of this code.\\n\",\n",
    "    \"Provide:\\n\",\n",
    "    \"- Big-O time complexity with explanation\\n\",\n",
    "    \"- Big-O space complexity\\n\",\n",
    "    \"- Best/worst/average case analysis\\n\",\n",
    "    \"- Suggest optimization if complexity can be improved\\\"\\\"\\\"),\\n\",\n",
    "    \"    (\\\"human\\\", \\\"Analyze complexity:\\\\n```python\\\\n{code}\\\\n```\\\")\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"complexity_chain = complexity_prompt | llm | StrOutputParser()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for name, sample in code_samples.items():\\n\",\n",
    "    \"    print(f\\\"\\\\n{'='*60}\\\")\\n\",\n",
    "    \"    print(f\\\"Complexity: {name}\\\")\\n\",\n",
    "    \"    print('='*60)\\n\",\n",
    "    \"    analysis = complexity_chain.invoke({\\\"code\\\": sample})\\n\",\n",
    "    \"    print(analysis)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## What You Learned\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. **Line-by-line code explanation** for any snippet\\n\",\n",
    "    \"2. **Automated bug detection** with structured output\\n\",\n",
    "    \"3. **Refactoring suggestions** with Pythonic improvements\\n\",\n",
    "    \"4. **Complexity analysis** with Big-O notation\\n\",\n",
    "    \"\\n\",\n",
    "    \"## Exercises\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. Analyze your own code\\n\",\n",
    "    \"2. Add cross-language translation\\n\",\n",
    "    \"3. Generate unit test suggestions\\n\",\n",
    "    \"4. Build a PR review checklist\\n\",\n",
    "    \"\\n\",\n",
    "    \"---\\n\",\n",
    "    \"\\n\",\n",
    "    \"*Beginner series complete! Next: **11-20 — Local RAG***\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
