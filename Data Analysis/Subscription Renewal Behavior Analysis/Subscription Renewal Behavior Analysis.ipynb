    "   \"id\": \"c005\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(f\\\"Missing values:\\\\n{df.isnull().sum()}\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nDuplicate IDs: {df['customer_id'].duplicated().sum()}\\\")\\n\",\n",
    "    \"print(f\\\"Outcomes: {df['outcome'].value_counts().to_dict()}\\\")\\n\",\n",
    "    \"print(f\\\"Satisfaction range: {df['satisfaction_score'].min()} - {df['satisfaction_score'].max()}\\\")\\n\",\n",
    "    \"print(\\\"\\\\n✅ Validation passed.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"m008\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Data Cleaning\\n\",\n",
    "    \"Dataset is clean by design. In practice you would handle missing satisfaction scores, resolve duplicate accounts, and verify outcome labeling.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"m009\",\n",
