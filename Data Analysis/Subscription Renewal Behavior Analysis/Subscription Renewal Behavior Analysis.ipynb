    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"c001\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import subprocess, sys, importlib\\n\",\n",
    "    \"for pkg in [\\\"pandas\\\", \\\"numpy\\\", \\\"matplotlib\\\", \\\"seaborn\\\", \\\"scipy\\\"]:\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        importlib.import_module(pkg)\\n\",\n",
    "    \"    except ImportError:\\n\",\n",
    "    \"        subprocess.check_call([sys.executable, \\\"-m\\\", \\\"pip\\\", \\\"install\\\", \\\"-q\\\", pkg])\\n\",\n",
    "    \"print(\\\"Environment ready.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"m004\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Imports\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"c002\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"from scipy import stats\\n\",\n",
    "    \"import warnings\\n\",\n",
    "    \"warnings.filterwarnings(\\\"ignore\\\")\\n\",\n",
    "    \"sns.set_style(\\\"whitegrid\\\")\\n\",\n",
    "    \"%matplotlib inline\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"m005\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Configuration / Constants\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"c003\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"SEED = 42\\n\",\n",
    "    \"N = 5000\\n\",\n",
    "    \"PLANS = [\\\"Basic\\\", \\\"Standard\\\", \\\"Premium\\\"]\\n\",\n",
    "    \"PLAN_PRICES = {\\\"Basic\\\": 9.99, \\\"Standard\\\": 19.99, \\\"Premium\\\": 39.99}\\n\",\n",
    "    \"PAYMENT_METHODS = [\\\"Credit Card\\\", \\\"PayPal\\\", \\\"Bank Transfer\\\", \\\"Apple Pay\\\"]\\n\",\n",
    "    \"OUTCOMES = [\\\"Renewed\\\", \\\"Cancelled\\\", \\\"Downgraded\\\"]\\n\",\n",
    "    \"print(\\\"Configuration loaded.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"m006\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Dataset Generation\\n\",\n",
    "    \"Subscribers with higher usage, longer tenure, and higher satisfaction scores are more likely to renew. Low engagement and support tickets signal churn risk.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"c004\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"rng = np.random.default_rng(SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"rows = []\\n\",\n",
    "    \"for i in range(N):\\n\",\n",
    "    \"    plan = rng.choice(PLANS, p=[0.40, 0.35, 0.25])\\n\",\n",
    "    \"    tenure = int(rng.exponential(12) + 1)\\n\",\n",
    "    \"    logins = max(0, int(rng.normal(15 if plan == \\\"Premium\\\" else 10 if plan == \\\"Standard\\\" else 6, 5)))\\n\",\n",
    "    \"    features = max(1, int(rng.normal(8 if plan == \\\"Premium\\\" else 5 if plan == \\\"Standard\\\" else 3, 2)))\\n\",\n",
    "    \"    tickets = max(0, int(rng.exponential(0.8)))\\n\",\n",
    "    \"    satisfaction = np.clip(int(rng.normal(7 if logins > 10 else 5.5, 1.5)), 1, 10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Outcome depends on engagement and satisfaction\\n\",\n",
    "    \"    renewal_score = (logins / 20) * 0.3 + (satisfaction / 10) * 0.4 + (min(tenure, 24) / 24) * 0.2 + (features / 10) * 0.1\\n\",\n",
    "    \"    renewal_score -= tickets * 0.05\\n\",\n",
    "    \"    renewal_score = np.clip(renewal_score + rng.normal(0, 0.1), 0, 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if renewal_score > 0.55:\\n\",\n",
    "    \"        outcome = \\\"Renewed\\\"\\n\",\n",
    "    \"    elif renewal_score > 0.35:\\n\",\n",
    "    \"        outcome = rng.choice([\\\"Downgraded\\\", \\\"Cancelled\\\"], p=[0.6, 0.4])\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        outcome = \\\"Cancelled\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    rows.append({\\n\",\n",
    "    \"        \\\"customer_id\\\": f\\\"CUST{i+1:05d}\\\",\\n\",\n",
    "    \"        \\\"plan\\\": plan,\\n\",\n",
    "    \"        \\\"monthly_price\\\": PLAN_PRICES[plan],\\n\",\n",
    "    \"        \\\"tenure_months\\\": tenure,\\n\",\n",
    "    \"        \\\"payment_method\\\": rng.choice(PAYMENT_METHODS, p=[0.40, 0.25, 0.20, 0.15]),\\n\",\n",
    "    \"        \\\"logins_last_30d\\\": logins,\\n\",\n",
    "    \"        \\\"features_used\\\": features,\\n\",\n",
    "    \"        \\\"support_tickets\\\": tickets,\\n\",\n",
    "    \"        \\\"satisfaction_score\\\": satisfaction,\\n\",\n",
    "    \"        \\\"outcome\\\": outcome,\\n\",\n",
    "    \"    })\\n\",\n",
    "    \"\\n\",\n",
    "    \"df = pd.DataFrame(rows)\\n\",\n",
    "    \"print(f\\\"Dataset shape: {df.shape}\\\")\\n\",\n",
    "    \"df.head()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"m007\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Data Validation Checks\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
