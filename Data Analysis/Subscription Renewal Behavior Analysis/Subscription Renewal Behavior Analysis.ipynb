    "   \"source\": [\n",
    "    \"fig, ax = plt.subplots(figsize=(8, 6))\\n\",\n",
    "    \"corr = df[numeric_cols].corr()\\n\",\n",
    "    \"sns.heatmap(corr, annot=True, fmt=\\\".2f\\\", cmap=\\\"coolwarm\\\", center=0, ax=ax)\\n\",\n",
    "    \"ax.set_title(\\\"Feature Correlation Heatmap\\\")\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
