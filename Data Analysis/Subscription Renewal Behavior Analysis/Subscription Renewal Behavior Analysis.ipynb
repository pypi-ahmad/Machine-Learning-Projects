    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(f\\\"Total subscribers: {len(df):,}\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nOutcome distribution:\\\")\\n\",\n",
    "    \"print(df[\\\"outcome\\\"].value_counts(normalize=True).map(\\\"{:.1%}\\\".format))\\n\",\n",
    "    \"print(f\\\"\\\\nPlan distribution:\\\")\\n\",\n",
    "    \"print(df[\\\"plan\\\"].value_counts())\\n\",\n",
    "    \"print(f\\\"\\\\nAvg satisfaction: {df['satisfaction_score'].mean():.1f}\\\")\\n\",\n",
    "    \"print(f\\\"Avg logins (30d): {df['logins_last_30d'].mean():.1f}\\\")\"\n",
    "   ]\n",
