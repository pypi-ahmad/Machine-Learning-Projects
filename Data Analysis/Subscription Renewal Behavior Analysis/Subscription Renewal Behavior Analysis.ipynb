    "   \"source\": [\n",
    "    \"fig, axes = plt.subplots(2, 2, figsize=(14, 10))\\n\",\n",
    "    \"\\n\",\n",
    "    \"axes[0,0].hist(df[\\\"tenure_months\\\"], bins=30, color=\\\"steelblue\\\", edgecolor=\\\"white\\\")\\n\",\n",
    "    \"axes[0,0].set_title(\\\"Tenure Distribution (months)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"axes[0,1].hist(df[\\\"logins_last_30d\\\"], bins=20, color=\\\"seagreen\\\", edgecolor=\\\"white\\\")\\n\",\n",
    "    \"axes[0,1].set_title(\\\"Logins Last 30 Days\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"df[\\\"satisfaction_score\\\"].value_counts().sort_index().plot(kind=\\\"bar\\\", ax=axes[1,0], color=\\\"coral\\\")\\n\",\n",
    "    \"axes[1,0].set_title(\\\"Satisfaction Score Distribution\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"df[\\\"outcome\\\"].value_counts().plot(kind=\\\"bar\\\", ax=axes[1,1], color=[\\\"#2ecc71\\\", \\\"#e74c3c\\\", \\\"#f39c12\\\"])\\n\",\n",
    "    \"axes[1,1].set_title(\\\"Outcome Distribution\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"m011\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Bivariate / Multivariate Analysis\\n\",\n",
    "    \"### How do usage metrics differ by outcome?\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"c008\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"outcome_summary = df.groupby(\\\"outcome\\\").agg(\\n\",\n",
    "    \"    count=(\\\"customer_id\\\", \\\"count\\\"),\\n\",\n",
    "    \"    avg_logins=(\\\"logins_last_30d\\\", \\\"mean\\\"),\\n\",\n",
    "    \"    avg_features=(\\\"features_used\\\", \\\"mean\\\"),\\n\",\n",
    "    \"    avg_satisfaction=(\\\"satisfaction_score\\\", \\\"mean\\\"),\\n\",\n",
    "    \"    avg_tenure=(\\\"tenure_months\\\", \\\"mean\\\"),\\n\",\n",
    "    \"    avg_tickets=(\\\"support_tickets\\\", \\\"mean\\\"),\\n\",\n",
    "    \").round(2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=== Subscriber Metrics by Outcome ===\\\")\\n\",\n",
    "    \"outcome_summary\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"c009\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig, axes = plt.subplots(1, 3, figsize=(16, 5))\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.boxplot(data=df, x=\\\"outcome\\\", y=\\\"logins_last_30d\\\", ax=axes[0], palette=\\\"Set2\\\",\\n\",\n",
    "    \"            order=[\\\"Renewed\\\", \\\"Downgraded\\\", \\\"Cancelled\\\"])\\n\",\n",
    "    \"axes[0].set_title(\\\"Logins by Outcome\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.boxplot(data=df, x=\\\"outcome\\\", y=\\\"satisfaction_score\\\", ax=axes[1], palette=\\\"Set2\\\",\\n\",\n",
    "    \"            order=[\\\"Renewed\\\", \\\"Downgraded\\\", \\\"Cancelled\\\"])\\n\",\n",
    "    \"axes[1].set_title(\\\"Satisfaction by Outcome\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.boxplot(data=df, x=\\\"outcome\\\", y=\\\"tenure_months\\\", ax=axes[2], palette=\\\"Set2\\\",\\n\",\n",
    "    \"            order=[\\\"Renewed\\\", \\\"Downgraded\\\", \\\"Cancelled\\\"])\\n\",\n",
    "    \"axes[2].set_title(\\\"Tenure by Outcome\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"m012\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"**Interpretation:** Renewed subscribers have higher logins, higher satisfaction, and tend to have been subscribed longer. Cancelled subscribers show low engagement across all dimensions — a clear warning signal.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"c010\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Renewal rate by plan\\n\",\n",
    "    \"plan_outcome = pd.crosstab(df[\\\"plan\\\"], df[\\\"outcome\\\"], normalize=\\\"index\\\")\\n\",\n",
    "    \"plan_outcome = plan_outcome.reindex(PLANS)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plan_outcome.plot(kind=\\\"bar\\\", stacked=True, figsize=(8, 5), color=[\\\"#e74c3c\\\", \\\"#f39c12\\\", \\\"#2ecc71\\\"])\\n\",\n",
    "    \"plt.title(\\\"Outcome Distribution by Plan\\\")\\n\",\n",
    "    \"plt.ylabel(\\\"Proportion\\\")\\n\",\n",
    "    \"plt.xticks(rotation=0)\\n\",\n",
    "    \"plt.legend(title=\\\"Outcome\\\")\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"m013\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Feature-Specific Insights\\n\",\n",
    "    \"### Satisfaction score as a predictor\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"c011\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"sat_renewal = df.groupby(\\\"satisfaction_score\\\")[\\\"outcome\\\"].value_counts(normalize=True).unstack(fill_value=0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(10, 5))\\n\",\n",
    "    \"sat_renewal.plot(kind=\\\"bar\\\", stacked=True, ax=ax, color=[\\\"#e74c3c\\\", \\\"#f39c12\\\", \\\"#2ecc71\\\"])\\n\",\n",
    "    \"ax.set_title(\\\"Outcome Proportion by Satisfaction Score\\\")\\n\",\n",
    "    \"ax.set_ylabel(\\\"Proportion\\\")\\n\",\n",
    "    \"ax.set_xlabel(\\\"Satisfaction Score\\\")\\n\",\n",
    "    \"plt.xticks(rotation=0)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"m014\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Statistical Checks\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"c012\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"renewed = df[df[\\\"outcome\\\"] == \\\"Renewed\\\"][\\\"satisfaction_score\\\"]\\n\",\n",
    "    \"cancelled = df[df[\\\"outcome\\\"] == \\\"Cancelled\\\"][\\\"satisfaction_score\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"stat, p = stats.mannwhitneyu(renewed, cancelled, alternative=\\\"greater\\\")\\n\",\n",
    "    \"print(f\\\"Renewed avg satisfaction: {renewed.mean():.2f}\\\")\\n\",\n",
    "    \"print(f\\\"Cancelled avg satisfaction: {cancelled.mean():.2f}\\\")\\n\",\n",
    "    \"print(f\\\"Mann-Whitney U: p={p:.6f} → {'Significant' if p < 0.05 else 'Not significant'}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Correlation matrix for numeric features\\n\",\n",
    "    \"numeric_cols = [\\\"logins_last_30d\\\", \\\"features_used\\\", \\\"support_tickets\\\", \\\"satisfaction_score\\\", \\\"tenure_months\\\"]\\n\",\n",
    "    \"print(\\\"\\\\nCorrelation matrix:\\\")\\n\",\n",
    "    \"df[numeric_cols].corr().round(2)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
