#%% md
# Headline Generator

## 1. Project Overview

**Task:** Generate multiple headline variants for articles — professional, engaging, question-based, data-driven — for editorial selection or A/B testing.

**Stack:** `LangChain` + `ChatOllama` + `qwen3.5:9b` — no API keys required.
#%% md
## 2. Learning Goals

| # | Skill |
|---|-------|
| 1 | **Generate** multiple headline variants from a single article |
| 2 | **Control** headline style — professional, clickbait, question, data-driven |
| 3 | **Compare** rule-based vs LLM-generated headlines |
| 4 | **Evaluate** headline quality on click-appeal and accuracy |

## 3. Problem Statement

Headlines determine whether content gets read. Editors test 5-10 variants per article. LLMs can generate diverse options quickly, but headlines must be accurate, compelling, and platform-appropriate.

## 4. Why This Matters

- **80% of readers** only read the headline
- **A/B testing headlines** increases CTR by 30-100%
- **Platform-specific** — LinkedIn differs from Twitter or email
#%% md
## 5. Setup
#%%
import os, json, re, time, warnings
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0.8)

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply with one word.', 'Say ready.')[:20]}")
#%% md
## 6. Sample Articles
#%%
ARTICLES = [
    {"id": 1, "topic": "AI/Tech", "summary": "MIT scientists developed an AI model predicting protein structures with 95% accuracy, processing sequences 10x faster than existing methods, identifying 3 drug candidates for rare diseases."},
    {"id": 2, "topic": "Climate", "summary": "Global temperatures hit record high in 2025 for the second year. Arctic ice at lowest level ever. 15 countries experienced their hottest year on record."},
    {"id": 3, "topic": "Business", "summary": "Federal Reserve announced surprise 50-basis-point rate cut, sending S&P 500 to all-time high of 6,200. Economists divided — some praise, others warn of reignited inflation."},
    {"id": 4, "topic": "Remote Work", "summary": "Stanford study of 3,000 companies: hybrid workers 13% more productive than in-office. Companies mandating return-to-office saw 35% increase in voluntary turnover."},
]
for a in ARTICLES:
    print(f"Article {a['id']} [{a['topic']}]: {a['summary'][:60]}...")
#%% md
---
## 7. Rule-Based Headline Extraction
#%%
def extract_headlines(text):
    numbers = re.findall(r'\d+[%.]?\d*', text)
    proper = re.findall(r'(?:^|\.\s+)([A-Z][a-z]+(?:\s[A-Z][a-z]+)*)', text)
    subject = proper[0] if proper else "Researchers"
    headlines = [f"Breaking: {subject} Announces Major Development", f"What {subject}'s Latest Move Means for the Industry"]
    if numbers:
        headlines.append(f"{subject} Achieves {numbers[0]}% — Why It Matters")
    return headlines

print("RULE-BASED HEADLINES")
print("=" * 60)
for a in ARTICLES:
    print(f"\nArticle {a['id']} [{a['topic']}]:")
    for h in extract_headlines(a["summary"]):
        print(f"  -> {h}")
#%% md
## 8. Multi-Style LLM Generation
#%%
HEADLINE_SYSTEM = """Generate 5 headline variants:
1. Professional/Neutral 2. Engaging/Clickable 3. Question-Style 4. Data-Driven 5. Contrarian/Surprising
Each under 15 words. Accurate to article. Numbered list only. /no_think"""

print("LLM MULTI-STYLE HEADLINES")
print("=" * 60)
llm_results = {}
for a in ARTICLES:
    headlines = ask(HEADLINE_SYSTEM, f"Article:\n{a['summary']}")
    llm_results[a["id"]] = headlines
    print(f"\nArticle {a['id']} [{a['topic']}]:")
    print(headlines)
#%% md
## 9. Platform-Specific Headlines
#%%
PLATFORMS = {
    "LinkedIn": "Professional, insight-driven, under 12 words. /no_think",
    "Twitter/X": "Punchy, strong verbs, under 10 words. /no_think",
    "Email subject": "Curiosity-driven, personal feel, under 10 words. /no_think",
    "SEO/Google": "Key search terms, clear topic, under 60 characters. /no_think",
}

a = ARTICLES[0]
print("PLATFORM-SPECIFIC HEADLINES")
print("=" * 60)
for platform, system in PLATFORMS.items():
    headline = ask(system, f"Article:\n{a['summary']}")
    print(f"  {platform:<20}: {headline}")
#%% md
## 10. Quality Evaluation
#%%
EVAL_SYSTEM = """Evaluate headline 1-5: click_appeal, accuracy, clarity, uniqueness, length.
Return JSON: {"click_appeal":N,"accuracy":N,"clarity":N,"uniqueness":N,"length":N,"total":N,"feedback":"note"} /no_think"""

a = ARTICLES[3]
test_headlines = [
    "Stanford Study: Hybrid Workers Are 13% More Productive",
    "The Return-to-Office Mandate Is Backfiring",
    "35% More Turnover: The Hidden Cost of Forcing Workers Back",
]
print("HEADLINE QUALITY")
print("=" * 60)
for headline in test_headlines:
    resp = ask(EVAL_SYSTEM, f"Article: {a['summary']}\n\nHeadline: {headline}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    if s >= 0 and e > s:
        try:
            sc = json.loads(text[s:e])
            total = sum(sc.get(k,0) for k in ["click_appeal","accuracy","clarity","uniqueness","length"])
            print(f"  [{total:>2}/25] {headline}")
        except: pass
#%% md
## 11. Emotional Framing
#%%
EMOTIONS = {"Fear": "Evoke concern or urgency.", "Hope": "Evoke optimism.", "Curiosity": "Make reader want to click.", "Authority": "Authoritative statement of fact."}
a = ARTICLES[0]
print("EMOTIONAL FRAMING")
print("=" * 60)
for emotion, guide in EMOTIONS.items():
    headline = ask(f"Frame headline with {emotion.lower()}. {guide} Under 12 words. /no_think", f"Article:\n{a['summary']}")
    print(f"  {emotion:<12}: {headline}")
