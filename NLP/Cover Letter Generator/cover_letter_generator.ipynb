## 7. Zero-Shot Generation
#%%
ZERO_SHOT_SYSTEM = """Write a professional cover letter.
- 3 paragraphs: opening, body (skills matching JD), closing (CTA)
- Match resume skills to JD requirements
- Professional, warm. Under 250 words. Return ONLY the letter"""

print("ZERO-SHOT COVER LETTERS")
print("=" * 60)
zero_shot_results = {}
for app in APPLICATIONS:
    letter = ask(ZERO_SHOT_SYSTEM, f"Resume:\n{app['resume']}\n\nJD:\n{app['job_description']}\n\nCompany: {app['company']}")
    zero_shot_results[app["id"]] = letter
    print(f"\n--- {app['id']} -> {app['company']} ---")
    print(letter)
    print(f"[{len(letter.split())} words]")
#%% md
## 8. Structured Template-Guided Generation
#%%
STRUCTURED_SYSTEM = """Write a cover letter:
PARA 1 HOOK: Name role/company, best achievement with numbers.
PARA 2 SKILL MATCH: Match 3-4 resume skills to JD with metrics.
PARA 3 CLOSE: Interest + CTA.
Under 200 words. Return ONLY the letter."""

structured_results = {}
for app in APPLICATIONS:
    letter = ask(STRUCTURED_SYSTEM, f"Resume:\n{app['resume']}\n\nJD:\n{app['job_description']}\n\nCompany: {app['company']}")
    structured_results[app["id"]] = letter
    print(f"\n--- {app['id']} ({len(letter.split())} words) ---")
    print(letter)
#%% md
## 9. Role-Based Prompting
#%%
ROLE_SYSTEM = """You are a career coach. Lead with impact. Match skills explicitly. Use numbers.
Under 200 words. Return ONLY the letter."""

role_results = {}
for app in APPLICATIONS:
    letter = ask(ROLE_SYSTEM, f"Resume:\n{app['resume']}\n\nJD:\n{app['job_description']}\n\nCompany: {app['company']}")
    role_results[app["id"]] = letter
    print(f"\n--- {app['id']} ({len(letter.split())} words) ---")
    print(letter)
#%% md
## 10. Quality Evaluation
#%%
EVAL_SYSTEM = """Evaluate cover letter 1-5: professionalism, personalization, structure, impact, length.
Return JSON: {"professionalism":N,"personalization":N,"structure":N,"impact":N,"length":N,"total":N,"feedback":"note"} /no_think"""

app = APPLICATIONS[0]
print("QUALITY COMPARISON")
print("=" * 60)
for name, res in [("Zero-shot", zero_shot_results), ("Structured", structured_results), ("Role-based", role_results)]:
    resp = ask(EVAL_SYSTEM, f"Resume:\n{app['resume']}\n\nJD:\n{app['job_description']}\n\nLetter:\n{res[app['id']]}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    if s >= 0 and e > s:
        try:
            scores = json.loads(text[s:e])
            total = sum(scores.get(k,0) for k in ["professionalism","personalization","structure","impact","length"])
            print(f"{name}: {total}/25 | {scores.get('feedback','')[:60]}")
        except: pass
#%% md
## 11. Tone Variants
#%%
TONES = {"Formal": "Formal corporate tone.", "Startup": "Conversational startup tone.", "Technical": "Technical audience."}
app = APPLICATIONS[0]
for tn, ti in TONES.items():
    letter = ask(f"{ZERO_SHOT_SYSTEM}\nTone: {ti}", f"Resume:\n{app['resume']}\n\nJD:\n{app['job_description']}\n\nCompany: {app['company']}")
    print(f"\n--- {tn} ({len(letter.split())} words) ---")
    print(letter[:300] + "...\n")
