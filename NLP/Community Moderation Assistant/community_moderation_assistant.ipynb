#%% md
# Community Moderation Assistant

## 1. Project Overview
**Task:** Prioritize risky or toxic posts for human moderator review using multi-dimensional safety scoring.
**Stack:** `LangChain` + `ChatOllama` + `qwen3.5:9b`.
#%% md
## 2. Why This Matters
- Reduce moderator workload with intelligent triage
- Multi-dimensional scoring catches different violation types
- Self-harm detection requires immediate escalation
#%% md
## 3. Setup
#%%
import os, json, re, warnings
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0)

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply OK.', 'Test')[:20]}")
#%% md
## 4. Sample Posts
#%%
POSTS = [
    {"text": "I love this community, everyone is so helpful!", "ctx": "general"},
    {"text": "This product is absolute garbage", "ctx": "review"},
    {"text": "You're an idiot if you believe that", "ctx": "debate"},
    {"text": "Check out my crypto course, guaranteed 100x!", "ctx": "spam"},
    {"text": "I can't take this anymore, everything feels hopeless", "ctx": "mental_health"},
    {"text": "The moderators here are power-tripping losers", "ctx": "meta"},
    {"text": "Great discussion, learned a lot!", "ctx": "general"},
    {"text": "Buy followers cheap at spamsite dot com!!!", "ctx": "spam"},
    {"text": "This is misinformation, the study was retracted", "ctx": "factcheck"},
    {"text": "Anyone know a good therapist? Struggling lately", "ctx": "support"},
    {"text": "I hope bad things happen to people who disagree", "ctx": "hostile"},
    {"text": "Here's a detailed comparison with benchmarks", "ctx": "technical"},
]
print(f"Posts: {len(POSTS)}")
#%% md
---
## 5. Safety Scoring
#%%
MOD_SYS = \"\"\"Score post for moderation. Return JSON:
{"toxicity":0-5,"spam_score":0-5,"self_harm_risk":0-5,"harassment":0-5,
"overall_risk":"safe|low|medium|high|critical",
"action":"approve|flag|review|remove|escalate","reason":"brief"} /no_think\"\"\"

print("MODERATION ANALYSIS")
print("=" * 80)
results = []
for p in POSTS:
    resp = ask(MOD_SYS, f"Post: {p['text']}\nContext: {p['ctx']}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    r = {"overall_risk":"?","action":"?","toxicity":0}
    if s >= 0 and e > s:
        try: r = json.loads(text[s:e])
        except: pass
    r["text"] = p["text"]
    results.append(r)
    print(f"  [{r.get('action','?'):<8}] risk={r.get('overall_risk','?'):<8} tox={r.get('toxicity',0)} {p['text'][:45]}...")
#%% md
## 6. Moderation Queue
#%%
RO = {"critical":0,"high":1,"medium":2,"low":3,"safe":4}
for r in sorted(results, key=lambda x: RO.get(x.get("overall_risk","safe"),5)):
    if r.get("overall_risk") in ("safe","low"): continue
    print(f"  [{r.get('overall_risk','?'):<8}] {r.get('action','?'):<8} | {r['text'][:55]}...")
    print(f"    Reason: {r.get('reason','')[:70]}\n")
#%% md
## 7. Summary
#%%
from collections import Counter
ac = Counter(r.get("action","?") for r in results)
print(f"Actions: {dict(ac)}")
