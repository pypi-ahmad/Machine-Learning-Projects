   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\"cell_type\":\"markdown\",\"metadata\":{},\"source\":[\"# Subtitle Cleaner and Translator\\n\",\"**NLP Project 69 of 100** — Clean subtitle text (remove timestamps, formatting) and translate.\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"import re, requests\\nimport warnings; warnings.filterwarnings('ignore')\\nprint('Loaded.')\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"# Sample SRT subtitle content\\nSRT_TEXT = \\\"\\\"\\\"1\\n00:00:01,000 --> 00:00:03,500\\nHello and welcome to this tutorial.\\n\\n2\\n00:00:03,600 --> 00:00:06,000\\nToday we will learn about machine learning.\\n\\n3\\n00:00:06,100 --> 00:00:09,000\\n<i>It is one of the most important fields</i>\\nin computer science.\\n\\n4\\n00:00:09,100 --> 00:00:12,000\\n[Music] Let's get started!\\n\\\"\\\"\\\"\\n\\ndef clean_srt(srt_text):\\n    lines = srt_text.strip().split('\\\\n')\\n    cleaned = []\\n    for line in lines:\\n        line = line.strip()\\n        if not line: continue\\n        if re.match(r'^\\\\d+$', line): continue  # Subtitle number\\n        if re.match(r'\\\\d{2}:\\\\d{2}:\\\\d{2}', line): continue  # Timestamp\\n        # Remove HTML/formatting tags\\n        line = re.sub(r'<[^>]+>', '', line)\\n        line = re.sub(r'\\\\[.*?\\\\]', '', line)  # Remove [Music] etc\\n        line = line.strip()\\n        if line:\\n            cleaned.append(line)\\n    return ' '.join(cleaned)\\n\\ncleaned = clean_srt(SRT_TEXT)\\nprint('=== Cleaned Text ===')\\nprint(cleaned)\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"# Translate cleaned text\\ndef translate(text, model='qwen3:1.7b'):\\n    prompt = f'Translate this English text to Spanish. Output only the translation.\\\\n\\\\n{text} /no_think'\\n    try:\\n        r = requests.post('http://localhost:11434/api/generate',json={'model':model,'prompt':prompt,'stream':False},timeout=60)\\n        return r.json().get('response','')\\n    except: return 'Translation unavailable (Ollama not running).'\\n\\nprint('\\\\n=== Translated ===')\\nprint(translate(cleaned))\"]},\n",
    "  {\"cell_type\":\"markdown\",\"metadata\":{},\"source\":[\"## Summary\\n\",\"- **SRT cleaning removes timestamps, numbers, and formatting tags.**\\n\",\"- **Translation of cleaned text produces better results** than translating raw SRT.\\n\",\"- **For production, preserve timestamp alignment** for re-formatted subtitles.\"]}\n",
    " ],\n",
