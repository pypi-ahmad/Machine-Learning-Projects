   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\"cell_type\":\"markdown\",\"metadata\":{},\"source\":[\"# Formal-to-Casual Rewriter\\n\",\"**NLP Project 49 of 100** — Change text tone from formal to casual while preserving meaning using LLMs.\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"import requests, json\\nimport warnings; warnings.filterwarnings('ignore')\\nprint('Loaded.')\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"formal_texts = [\\n    'We would like to inform you that your application has been received and is currently under review.',\\n    'Please be advised that the meeting has been rescheduled to Friday at 14:00 hours.',\\n    'We regret to inform you that we are unable to process your request at this time.',\\n    'It has come to our attention that there may be discrepancies in the submitted documentation.',\\n]\\n\\ndef rewrite_casual(text, model='qwen3:1.7b'):\\n    prompt = f'Rewrite this formal text in a casual, friendly tone. Keep the same meaning. Output only the rewritten text.\\\\n\\\\nFormal: {text} /no_think'\\n    try:\\n        r = requests.post('http://localhost:11434/api/generate',json={'model':model,'prompt':prompt,'stream':False},timeout=60)\\n        return r.json().get('response','')\\n    except:\\n        # Fallback: simple rule-based\\n        casual = text.replace('We would like to inform you','Hey, just letting you know')\\n        casual = casual.replace('Please be advised','Heads up')\\n        casual = casual.replace('We regret to inform you','Sorry, but')\\n        casual = casual.replace('It has come to our attention','We noticed')\\n        return casual\\n\\nfor formal in formal_texts:\\n    casual = rewrite_casual(formal)\\n    print(f'FORMAL: {formal}')\\n    print(f'CASUAL: {casual}')\\n    print()\"]},\n",
    "  {\"cell_type\":\"markdown\",\"metadata\":{},\"source\":[\"## Summary\\n\",\"- **Tone rewriting preserves information** while changing register.\\n\",\"- **LLMs handle nuanced tone shifts** better than rules.\\n\",\"- **Rule-based fallback works for common formal phrases.**\\n\",\"- **Use cases: customer communication, internal docs, social media adaptation.**\"]}\n",
    " ],\n",
