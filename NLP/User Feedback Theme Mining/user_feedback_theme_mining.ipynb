## 5. Theme Extraction
#%%
THEME_SYS = \"\"\"Identify main themes from these reviews.
Return JSON: {"themes":[{"name":"...","count":0,"sentiment":"positive|negative|mixed","priority":"high|medium|low"}]} /no_think\"\"\"

reviews_text = "\n".join(f"[{r['rating']}*] {r['text']}" for r in REVIEWS)
resp = ask(THEME_SYS, f"Reviews:\n{reviews_text}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
if s >= 0 and e > s:
    try:
        themes = json.loads(text[s:e]).get("themes", [])
        for t in themes: print(f"  [{t.get('priority','?'):<6}] [{t.get('sentiment','?'):<8}] {t.get('name','?')}")
    except: pass
#%% md
## 6. Per-Review Classification
#%%
CLS_SYS = \"\"\"Classify review. Return JSON:
{"theme":"bugs|ui|features|performance|praise|other","sentiment":"positive|negative|neutral",
"is_feature_request":true/false,"urgency":"high|medium|low"} /no_think\"\"\"

print("CLASSIFICATION")
print("=" * 70)
classified = []
for r in REVIEWS:
    resp = ask(CLS_SYS, f"Review [{r['rating']}*]: {r['text']}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    c = {"theme":"?","sentiment":"?"}
    if s >= 0 and e > s:
        try: c = json.loads(text[s:e])
        except: pass
    c["text"] = r["text"]
    classified.append(c)
    print(f"  [{c.get('theme','?'):<12}] [{c.get('sentiment','?'):<8}] {r['text'][:50]}...")

frs = [c for c in classified if c.get("is_feature_request")]
print(f"\nFeature Requests: {len(frs)}")
for f in frs: print(f"  - {f['text'][:70]}")
#%% md
