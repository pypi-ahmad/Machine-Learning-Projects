## 5. Phrase Extraction
#%%
EXT_SYS = \"\"\"Extract notable phrases, slang, jargon from these posts.
Return JSON: {"phrases":[{"phrase":"...","meaning":"...","type":"slang|technical|cultural","novelty":"new|established"}]} /no_think\"\"\"

print("PERIOD A PHRASES")
resp_a = ask(EXT_SYS, "Posts:\n" + "\n".join(PERIOD_A))
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
phrases_a = []
if s >= 0 and e > s:
    try: phrases_a = json.loads(text[s:e]).get("phrases", [])
    except: pass
for p in phrases_a: print(f"  [{p.get('type','?'):<10}] {p.get('phrase','?')}")

print("\nPERIOD B PHRASES")
resp_b = ask(EXT_SYS, "Posts:\n" + "\n".join(PERIOD_B))
text = resp_b
if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
s, e = text.find("{"), text.rfind("}") + 1
phrases_b = []
if s >= 0 and e > s:
    try: phrases_b = json.loads(text[s:e]).get("phrases", [])
    except: pass
for p in phrases_b: print(f"  [{p.get('type','?'):<10}] {p.get('phrase','?')}")
#%% md
## 6. Trend Comparison
#%%
TREND_SYS = \"\"\"Compare language trends. Identify NEW in B, DECLINED from A, PERSISTED.
Return JSON: {"emerging":[],"declining":[],"persistent":[],"analysis":"brief"} /no_think\"\"\"
pa = [p.get("phrase","") for p in phrases_a]
pb = [p.get("phrase","") for p in phrases_b]
resp = ask(TREND_SYS, f"Period A: {', '.join(pa)}\nPeriod B: {', '.join(pb)}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
if s >= 0 and e > s:
    try:
        r = json.loads(text[s:e])
        print(f"Emerging: {', '.join(r.get('emerging',[]))}")
        print(f"Declining: {', '.join(r.get('declining',[]))}")
    except: print(resp[:200])
