#%% md
# Trend Phrase Detector

## 1. Project Overview
**Task:** Surface emerging phrases and slang by comparing language across time periods.
**Stack:** `LangChain` + `ChatOllama` + `qwen3.5:9b`.
#%% md
## 2. Why This Matters
- Detect emerging slang and jargon
- Track phrase lifecycle: emerging, peak, declining
- Enable proactive content strategy
#%% md
## 3. Setup
#%%
import os, json, re, warnings
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0)

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply OK.', 'Test')[:20]}")
#%% md
## 4. Posts by Time Period
#%%
PERIOD_A = [
