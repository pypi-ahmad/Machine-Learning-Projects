## 7. Template-Based Descriptions
#%%
def template_description(product):
    features_str = ", ".join(product["features"][:-1]) + f", and {product['features'][-1]}"
    return f"Introducing the {product['name']} by {product['brand']}. Featuring {features_str}, this product delivers exceptional value at ${product['price']:.2f}. Perfect for {product['target_audience']}."

print("TEMPLATE-BASED DESCRIPTIONS")
print("=" * 60)
for p in PRODUCTS:
    print(f"\n--- {p['name']} ---")
    print(template_description(p))
#%% md
## 8. Zero-Shot LLM Generation
#%%
ZERO_SHOT_SYSTEM = """Write a compelling e-commerce product description.
- 2-3 sentences. Highlight top 2-3 features naturally (benefits, not specs)
- Create desire. Include subtle CTA. Professional but engaging
- Do NOT start with "Introducing". Return ONLY the description /no_think"""

print("LLM DESCRIPTIONS")
print("=" * 60)
llm_results = {}
for p in PRODUCTS:
    desc = ask(ZERO_SHOT_SYSTEM, f"Product: {p['name']}\nBrand: {p['brand']}\nCategory: {p['category']}\nPrice: ${p['price']}\nFeatures: {', '.join(p['features'])}\nAudience: {p['target_audience']}")
    llm_results[p["name"]] = desc
    print(f"\n--- {p['name']} ---")
    print(desc)
#%% md
## 9. Audience-Targeted Descriptions
#%%
p = PRODUCTS[0]
audiences = {
    "Tech enthusiast": "Tech enthusiasts who care about specs and audio quality",
    "Fitness user": "Gym-goers who need durable, sweat-proof audio",
    "Commuter": "Daily commuters who want noise cancellation for trains",
}

print("AUDIENCE-TARGETED DESCRIPTIONS")
print("=" * 60)
for audience_name, audience_desc in audiences.items():
    desc = ask(f"Write a product description for: {audience_desc}\n2-3 sentences. Emphasize benefits for this audience. /no_think",
        f"Product: {p['name']}\nFeatures: {', '.join(p['features'])}\nPrice: ${p['price']}")
    print(f"\n--- {audience_name} ({len(desc.split())} words) ---")
    print(desc)
#%% md
## 10. Quality Evaluation
#%%
EVAL_SYSTEM = """Evaluate product description 1-5: persuasiveness, feature_coverage, tone, uniqueness, seo_friendly.
Return JSON: {"persuasiveness":N,"feature_coverage":N,"tone":N,"uniqueness":N,"seo_friendly":N,"total":N,"feedback":"note"} /no_think"""

print("QUALITY COMPARISON")
print("=" * 60)
for p in PRODUCTS[:3]:
    for label, desc in [("Template", template_description(p)), ("LLM", llm_results.get(p["name"],"N/A"))]:
        resp = ask(EVAL_SYSTEM, f"Product: {p['name']}\nFeatures: {', '.join(p['features'])}\n\nDescription:\n{desc}")
        text = resp
        if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
        s, e = text.find("{"), text.rfind("}") + 1
        if s >= 0 and e > s:
            try:
                sc = json.loads(text[s:e])
                total = sum(sc.get(k,0) for k in ["persuasiveness","feature_coverage","tone","uniqueness","seo_friendly"])
                print(f"{p['name'][:25]:<28} {label:<10} {total}/25")
            except: pass
#%% md
## 11. SEO-Optimized Descriptions
#%%
SEO_SYSTEM = """Write an SEO-optimized product description.
Include product name and category naturally. Use 2-3 search keywords naturally.
2-3 sentences. Human-first, search-engine-friendly. /no_think"""

p = PRODUCTS[3]
desc = ask(SEO_SYSTEM, f"Product: {p['name']}\nBrand: {p['brand']}\nCategory: {p['category']}\nFeatures: {', '.join(p['features'])}\nAudience: {p['target_audience']}")
print("SEO-OPTIMIZED DESCRIPTION")
print("=" * 60)
print(f"{p['name']}: {desc}")
