    {"text": "FIRST!!! Subscribe to my channel for free iPhone!!!", "likes": 0},
    {"text": "Would love a PyTorch vs JAX performance comparison video", "likes": 234},
    {"text": "Audio quality needs work, hard to hear", "likes": 45},
    {"text": "Error at 14:32, the import doesn't work", "likes": 78},
    {"text": "This saved my project deadline, thank you!", "likes": 156},
    {"text": "Please add timestamps to your videos", "likes": 201},
    {"text": "Worst explanation ever", "likes": 3},
]
print(f"Comments: {len(COMMENTS)}")
#%% md
---
## 5. Multi-Dimensional Classification
#%%
CLS_SYS = \"\"\"Analyze this YouTube comment. Return JSON:
{"sentiment":"positive|negative|neutral","category":"praise|criticism|question|feature_request|spam|bug_report|toxic",
"toxicity_score":0-5,"actionable":true/false,"priority":"high|medium|low"} /no_think\"\"\"

print("COMMENT ANALYSIS")
print("=" * 70)
results = []
for c in COMMENTS:
    resp = ask(CLS_SYS, f"Comment: {c['text']}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    r = {"sentiment":"?","category":"?","toxicity_score":0,"actionable":False,"priority":"low"}
    if s >= 0 and e > s:
        try: r = json.loads(text[s:e])
        except: pass
    r["text"] = c["text"]
    results.append(r)
    print(f"  [{r.get('category','?'):<15}] [{r.get('sentiment','?'):<8}] tox={r.get('toxicity_score',0)} {c['text'][:45]}...")
#%% md
## 6. Categories & Actionable Items
#%%
cc = Counter(r.get("category","?") for r in results)
print("CATEGORIES")
for cat, cnt in cc.most_common(): print(f"  {cat:<18} {cnt:>2}")

print("\nACTIONABLE ITEMS")
for r in [x for x in results if x.get("actionable")]:
    print(f"  [{r.get('priority','?')}] {r['text'][:55]}...")
#%% md
## 7. Creator Summary
#%%
SUM_SYS = "Summarize these comment analytics for the creator briefly. /no_think"
analytics = json.dumps([{"cat":r.get("category"),"sent":r.get("sentiment"),"text":r["text"][:50]} for r in results])
print(ask(SUM_SYS, analytics))
