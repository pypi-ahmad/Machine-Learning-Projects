#%% md
# YouTube Comment Analyzer

## 1. Project Overview
**Task:** Analyze YouTube comments for sentiment, toxicity, and feature requests.
**Stack:** `LangChain` + `ChatOllama` + `qwen3.5:9b`.
#%% md
## 2. Why This Matters
- Prioritize actionable feedback for creators
- Detect toxic or spam comments for moderation
#%% md
## 3. Setup
#%%
from collections import Counter
import os, json, re, warnings
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0)

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply OK.', 'Test')[:20]}")
#%% md
## 4. Sample Comments
#%%
COMMENTS = [
    {"text": "Great tutorial! Please do diffusion models next!", "likes": 342},
    {"text": "This video is trash, you don't know what you're talking about", "likes": 5},
    {"text": "Can you share the code? GitHub link is broken", "likes": 89},
