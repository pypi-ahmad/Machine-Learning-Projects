#%% md
# Influencer Brand Mention Tracker

## 1. Project Overview
**Task:** Extract product/brand mentions from social posts, categorize by sentiment and mention type.
**Stack:** `LangChain` + `ChatOllama` + `qwen3.5:9b`.
#%% md
## 2. Why This Matters
- Brand reputation monitoring
- Sponsored vs organic detection
- Competitive share-of-voice analysis
#%% md
## 3. Setup
#%%
from collections import Counter
import os, json, re, warnings
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0)

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply OK.', 'Test')[:20]}")
#%% md
## 4. Sample Posts
#%%
POSTS = [
    {"text": "Obsessed with my new Nike Air Max! Best running shoes ever #nike", "platform": "Instagram"},
    {"text": "Switched from iPhone to Samsung Galaxy S25, not looking back", "platform": "Twitter"},
    {"text": "AD | Loving Olaplex No.3! Use code SARAH20 for 20% off", "platform": "Instagram"},
    {"text": "Starbucks peppermint mocha is amazing, gingerbread latte is meh", "platform": "TikTok"},
    {"text": "Tesla Model 3 vs BMW i4 - which EV should I get?", "platform": "Twitter"},
    {"text": "My Dyson vacuum broke after 6 months. Going back to Shark.", "platform": "Twitter"},
    {"text": "Date night look using all Fenty Beauty products!", "platform": "TikTok"},
    {"text": "Notion is so much better than Asana for project management", "platform": "LinkedIn"},
]
print(f"Posts: {len(POSTS)}")
#%% md
---
## 5. Brand Extraction
#%%
EXT_SYS = \"\"\"Extract brand/product mentions. Return JSON:
{"mentions":[{"brand":"...","product":"...","sentiment":"positive|negative|neutral","mention_type":"organic|sponsored|comparison|complaint"}]} /no_think\"\"\"

print("BRAND EXTRACTION")
print("=" * 70)
all_mentions = []
for p in POSTS:
    resp = ask(EXT_SYS, f"[{p['platform']}] {p['text']}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    mentions = []
    if s >= 0 and e > s:
        try: mentions = json.loads(text[s:e]).get("mentions", [])
        except: pass
    all_mentions.extend(mentions)
    brands = ", ".join(f"{m.get('brand','?')}({m.get('sentiment','?')[0]})" for m in mentions)
    print(f"  [{p['platform']:<9}] {brands:<40} {p['text'][:40]}...")
#%% md
## 6. Share-of-Voice & Sentiment
#%%
bc = Counter(m.get("brand","?") for m in all_mentions)
print("SHARE-OF-VOICE")
for b, c in bc.most_common(): print(f"  {b:<20} {c:>2} {'#'*(c*4)}")

print("\nSENTIMENT BY BRAND")
for b in set(m.get("brand","?") for m in all_mentions):
    sents = Counter(m.get("sentiment","?") for m in all_mentions if m.get("brand")==b)
    print(f"  {b:<20} {dict(sents)}")
