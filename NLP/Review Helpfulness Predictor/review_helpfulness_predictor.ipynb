#%% md
# Review Helpfulness Predictor

## 1. Project Overview
**Task:** Predict whether a product review is helpful based on content, specificity, and structure.
**Stack:** `LangChain` + `ChatOllama` + `qwen3.5:9b`.
#%% md
## 2. Why This Matters
- Surface informative reviews for shoppers
- Identify what makes reviews useful
- Help reviewers write better reviews
#%% md
## 3. Setup
#%%
import os, json, re, warnings
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0)

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply OK.', 'Test')[:20]}")
#%% md
## 4. Sample Reviews
#%%
REVIEWS = [
    {"text": "Great product!", "rating": 5, "votes": 2},
    {"text": "Bought this laptop for dev. 16GB RAM handles Docker and VS Code smoothly. Battery 6hrs. Keyboard comfortable. Trackpad a bit small.", "rating": 4, "votes": 89},
    {"text": "Terrible. Don't buy.", "rating": 1, "votes": 1},
    {"text": "Using this blender 3 months. Crushes ice perfectly. Lid leaks past max line. Motor quiet vs my old Vitamix. Easy cleanup. Good value.", "rating": 4, "votes": 156},
    {"text": "Works as expected.", "rating": 4, "votes": 5},
    {"text": "DO NOT BUY!!! SCAM!!! Waited 3 weeks, broken item!!!", "rating": 1, "votes": 8},
    {"text": "Researched 10+ standing desks. Assembly 45min solo. Motor quiet 42dB. Height 28-48in, fits 6'2. 30% cheaper than Uplift V2. 6 months in, perfect.", "rating": 5, "votes": 234},
    {"text": "five stars love it", "rating": 5, "votes": 0},
]
print(f"Reviews: {len(REVIEWS)}")
#%% md
---
## 5. Helpfulness Scoring
#%%
HELP_SYS = \"\"\"Score review helpfulness (1-10). Evaluate specificity, balance (pros+cons), use_case, comparative, time_tested.
Return JSON: {"helpfulness_score":0,"specificity":1-5,"balanced":1-5,"use_case":true/false,"comparative":true/false,"time_tested":true/false,"reasoning":"brief"} /no_think\"\"\"

print("HELPFULNESS ANALYSIS")
print("=" * 80)
scored = []
for r in REVIEWS:
    resp = ask(HELP_SYS, f"Review [{r['rating']}*]: {r['text']}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    sc = {"helpfulness_score":0}
    if s >= 0 and e > s:
        try: sc = json.loads(text[s:e])
        except: pass
    sc["text"] = r["text"]
    sc["votes"] = r["votes"]
    scored.append(sc)
    print(f"  Score={sc.get('helpfulness_score',0):<3} Votes={r['votes']:<4} {r['text'][:55]}...")
#%% md
## 6. Predicted vs Actual
#%%
print("PREDICTED vs ACTUAL")
print("=" * 60)
for sc in sorted(scored, key=lambda x: x.get("helpfulness_score",0), reverse=True):
    print(f"  {sc.get('helpfulness_score',0):>4}/10 {sc['votes']:>5} votes   {sc['text'][:40]}...")
#%% md
## 7. Key Takeaways

| # | Takeaway |
|---|----------|
| 1 | Specificity (details, measurements) matters most |
| 2 | Balanced reviews (pros AND cons) are trusted more |
| 3 | Time-tested reviews carry more weight |
| 4 | LLM scoring aligns with actual helpful votes |

