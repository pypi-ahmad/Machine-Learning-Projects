---
## 6. LLM Topic Classification
#%%
TOPIC_SYS = \"\"\"Classify tweet into ONE topic: Technology/AI, Finance/Economy, Entertainment, Environment/Climate, Health/Wellness, Lifestyle/Food, Politics/Social.
Return JSON: {"topic": "...", "confidence": 0.0-1.0} /no_think\"\"\"

print("TOPIC CLASSIFICATION")
print("=" * 70)
for t in TWEETS:
    resp = ask(TOPIC_SYS, f"Tweet: {t['text']}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    topic = "Unknown"
    if s >= 0 and e > s:
        try: topic = json.loads(text[s:e]).get("topic", "Unknown")
        except: pass
    t["topic"] = topic
    print(f"  [{t['date'].strftime('%m-%d')}] {topic:<20} {t['text'][:50]}...")
#%% md
## 7. Topic Distribution
#%%
topic_counts = Counter(t["topic"] for t in TWEETS)
print("TOPIC DISTRIBUTION")
print("=" * 40)
for topic, count in topic_counts.most_common():
    print(f"  {topic:<20} {count:>2} {'#' * (count * 3)}")
#%% md
## 8. Trends Over Time
#%%
days = sorted(set(t["date"] for t in TWEETS))
print("TOPIC TRENDS BY DAY")
for day in days:
    dt = [t for t in TWEETS if t["date"] == day]
    print(f"  {day.strftime('%Y-%m-%d')}: {', '.join(t.get('topic','?') for t in dt)}")
#%% md
## 9. Emerging Topic Detection
#%%
TREND_SYS = \"\"\"Identify rising, declining, emerging topics from this timeline.
Return JSON: {"rising": [], "declining": [], "emerging": [], "analysis": "brief"} /no_think\"\"\"
timeline = "\n".join(f"{d.strftime('%m-%d')}: {', '.join(t.get('topic','?') for t in TWEETS if t['date']==d)}" for d in days)
resp = ask(TREND_SYS, f"Timeline:\n{timeline}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
if s >= 0 and e > s:
    try:
        r = json.loads(text[s:e])
        print(f"Rising: {', '.join(r.get('rising',[]))}")
        print(f"Declining: {', '.join(r.get('declining',[]))}")
        print(f"Emerging: {', '.join(r.get('emerging',[]))}")
    except: print(resp[:200])
