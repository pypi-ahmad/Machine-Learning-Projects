## 7. Rule-Based SEO Metadata
#%%
def rule_based_seo(page):
    title = page["h1"]
    if len(title) < 50: title += " | Complete Guide"
    title = title[:60]
    desc = page["content"][:120].rstrip()
    if "." in desc: desc = desc[:desc.rfind(".")+1]
    primary_kw = page["keywords"][0]
    if primary_kw.lower() not in desc.lower(): desc = f"{primary_kw}: {desc}"
    desc = desc[:160]
    return {"title": title, "description": desc}

print("RULE-BASED SEO METADATA")
print("=" * 60)
rule_results = {}
for p in PAGES:
    meta = rule_based_seo(p)
    rule_results[p["url"]] = meta
    print(f"\n{p['url']}")
    print(f"  Title ({len(meta['title'])} chars): {meta['title']}")
    print(f"  Desc  ({len(meta['description'])} chars): {meta['description']}")
#%% md
## 8. Zero-Shot LLM Generation
#%%
SEO_SYSTEM = """Generate SEO-optimized title tag and meta description.
STRICT: Title 50-60 characters. Description 150-160 characters.
Include primary keyword near start. Description needs CTA.
Format: Title: [title]\nDescription: [description] /no_think"""

print("LLM SEO METADATA")
print("=" * 60)
llm_results = {}
for p in PAGES:
    resp = ask(SEO_SYSTEM, f"Page: {p['h1']}\nURL: {p['url']}\nType: {p['page_type']}\nKeywords: {', '.join(p['keywords'])}\nContent: {p['content']}")
    title_match = re.search(r"Title:\s*(.+?)(?:\n|$)", resp)
    desc_match = re.search(r"Description:\s*(.+?)(?:\n|$)", resp)
    meta = {"title": title_match.group(1).strip() if title_match else resp[:60], "description": desc_match.group(1).strip() if desc_match else resp[:160]}
    llm_results[p["url"]] = meta
    print(f"\n{p['url']}")
    print(f"  Title ({len(meta['title'])} chars): {meta['title']}")
    print(f"  Desc  ({len(meta['description'])} chars): {meta['description']}")
#%% md
## 9. Page-Type Specific Generation
#%%
PAGE_SYSTEMS = {
    "blog": "Blog post SEO. Title includes topic + value hook. Desc previews value. /no_think",
    "listicle": "Listicle SEO. Title includes number of items. Desc highlights comparison. /no_think",
    "tutorial": "Tutorial SEO. Title includes 'Guide'/'Tutorial'. Desc mentions what reader learns. /no_think",
    "landing": "Landing page SEO. Title includes product + value prop. Desc mentions pricing. /no_think",
}

for p in PAGES:
    system = f"Title: 50-60 chars. Description: 150-160 chars. Keywords: {', '.join(p['keywords'])}.\n{PAGE_SYSTEMS.get(p['page_type'], SEO_SYSTEM)}"
    resp = ask(system, f"Page: {p['h1']}\nContent: {p['content']}")
    print(f"\n{p['url']} [{p['page_type']}]:")
    print(f"  {resp[:200]}")
#%% md
## 10. Quality Evaluation
#%%
EVAL_SYSTEM = """Evaluate SEO metadata 1-5: keyword_usage, click_appeal, accuracy, length_compliance, uniqueness.
Return JSON: {"keyword_usage":N,"click_appeal":N,"accuracy":N,"length_compliance":N,"uniqueness":N,"total":N,"feedback":"note"} /no_think"""

print("QUALITY COMPARISON")
print("=" * 60)
for p in PAGES[:3]:
    for label, res in [("Rule", rule_results), ("LLM", llm_results)]:
        meta = res.get(p["url"], {})
        resp = ask(EVAL_SYSTEM, f"Page: {p['h1']}\nKeywords: {', '.join(p['keywords'])}\n\nTitle: {meta.get('title','')}\nDescription: {meta.get('description','')}")
        text = resp
        if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
        s, e = text.find("{"), text.rfind("}") + 1
        if s >= 0 and e > s:
            try:
                sc = json.loads(text[s:e])
                total = sum(sc.get(k,0) for k in ["keyword_usage","click_appeal","accuracy","length_compliance","uniqueness"])
                print(f"{p['url'][:25]:<28} {label:<6} {total}/25")
            except: pass
#%% md
## 11. Validation
#%%
def validate_seo(title, description, keywords):
    issues = []
    if len(title) < 30: issues.append(f"Title short ({len(title)} chars)")
    if len(title) > 65: issues.append(f"Title long ({len(title)} chars)")
    if len(description) < 120: issues.append(f"Desc short ({len(description)} chars)")
    if len(description) > 165: issues.append(f"Desc long ({len(description)} chars)")
    if not any(kw.lower() in title.lower() for kw in keywords): issues.append("Keyword missing from title")
    return issues or ["All checks passed"]

print("BULK VALIDATION")
print("=" * 60)
for p in PAGES:
    meta = llm_results.get(p["url"], {})
    issues = validate_seo(meta.get("title",""), meta.get("description",""), p["keywords"])
    print(f"\n{'PASS' if issues==['All checks passed'] else 'WARN'} {p['url']}")
    for i in issues: print(f"  - {i}")
#%% md
## 12. Common Mistakes & Key Takeaways

| Mistake | Fix |
|---------|-----|
| Exceeding character limits | Validate every title (60) and description (160) |
| Keyword stuffing | Include keyword once, naturally |
| Duplicate metadata | Generate unique content per page |
| No CTA | End descriptions with action phrase |

| # | Takeaway |
|---|----------|
| 1 | **Character limits matter** — Google truncates long titles/descriptions |
| 2 | **Keyword near start** improves relevance signals |
| 3 | **Page-type prompts** produce better metadata |
| 4 | **Validation is essential** — always check counts |
| 5 | **Rule-based ensures compliance**, LLMs ensure creativity |

