# Code-Mixed Text Classifier

## 1. Project Overview

**Task:** Classify sentiment in code-mixed text (Hinglish, Spanglish, Arabizi).

**Stack:** `LangChain` + `ChatOllama` + `qwen3.5:9b` for LLM classification, `sklearn` TF-IDF baseline.
#%% md
## 2. Learning Goals

| # | Skill |
|---|-------|
| 1 | **Understand** why code-mixed text breaks standard NLP tools |
| 2 | **Compare** char-ngram TF-IDF vs LLM for code-mixed classification |
| 3 | **Handle** Hinglish, Spanglish, and Arabizi in a single pipeline |
| 4 | **Evaluate** classification across different mixing styles |

## 3. Why This Matters

- **Social media analytics** - most non-English social media contains code-mixing
- **Standard tokenizers break** on mixed-script text
- **Sentiment analysis** must work regardless of language mixing patterns
#%% md
## 4. Setup
#%%
import os, json, re, warnings
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0)

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply with one word.', 'Say ready.')[:20]}")
#%% md
## 5. Code-Mixed Dataset
#%%
DATA = [
    {"text": "yeh movie bahut acchi hai, must watch!", "mix": "Hinglish", "sentiment": "positive"},
    {"text": "kya bakwas movie hai, total time waste", "mix": "Hinglish", "sentiment": "negative"},
    {"text": "bohot maza aaya, amazing performance", "mix": "Hinglish", "sentiment": "positive"},
    {"text": "worst film ever, paisa barbaad ho gaya", "mix": "Hinglish", "sentiment": "negative"},
    {"text": "director ne kamaal kar diya, brilliant", "mix": "Hinglish", "sentiment": "positive"},
    {"text": "acting bekaar thi, avoid karo", "mix": "Hinglish", "sentiment": "negative"},
    {"text": "This restaurant es muy bueno, loved it!", "mix": "Spanglish", "sentiment": "positive"},
    {"text": "The service was horrible, que asco", "mix": "Spanglish", "sentiment": "negative"},
    {"text": "La comida is amazing, highly recommend", "mix": "Spanglish", "sentiment": "positive"},
    {"text": "Never going back, que lugar tan malo", "mix": "Spanglish", "sentiment": "negative"},
    {"text": "Me encanta this place, best tacos ever", "mix": "Spanglish", "sentiment": "positive"},
    {"text": "Worst experience de mi vida, terrible", "mix": "Spanglish", "sentiment": "negative"},
    {"text": "hal movie kteer helwe, must see!", "mix": "Arabizi", "sentiment": "positive"},
    {"text": "shu hal film el boring, waste of time", "mix": "Arabizi", "sentiment": "negative"},
]

print(f"Dataset: {len(DATA)} samples")
for mix_type in ["Hinglish", "Spanglish", "Arabizi"]:
    count = sum(1 for d in DATA if d["mix"] == mix_type)
    print(f"  {mix_type}: {count} samples")
#%% md
---
## 6. TF-IDF Baseline
#%%
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score

texts = [d["text"] for d in DATA]
labels = [d["sentiment"] for d in DATA]
tfidf = TfidfVectorizer(analyzer="char_wb", ngram_range=(3, 5), max_features=3000)
X = tfidf.fit_transform(texts)
lr = LogisticRegression(max_iter=500, random_state=42)
lr.fit(X, labels)
baseline_preds = lr.predict(X)
print(f"Char-ngram TF-IDF baseline accuracy (train): {accuracy_score(labels, baseline_preds):.1%}")
#%% md
## 7. LLM Zero-Shot Classification
#%%
CLASSIFY_SYSTEM = """Classify code-mixed text sentiment as positive or negative.
Text may mix Hindi+English, Spanish+English, or Arabic+English.
Return JSON: {"sentiment": "positive"|"negative", "confidence": 0.0-1.0} /no_think"""

print("LLM ZERO-SHOT CLASSIFICATION")
print("=" * 70)
llm_correct = 0
for d in DATA:
    resp = ask(CLASSIFY_SYSTEM, f"Text: {d['text']}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    predicted = "neutral"
    if s >= 0 and e > s:
        try: predicted = json.loads(text[s:e]).get("sentiment", "neutral").lower()
        except: pass
    match = predicted == d["sentiment"]
    if match: llm_correct += 1
    print(f"  [{d['mix']:<10}] {d['sentiment']:<8} -> {predicted:<8} {'OK' if match else 'MISS'}")

print(f"\nLLM accuracy: {llm_correct}/{len(DATA)} = {llm_correct/len(DATA):.1%}")
#%% md
## 8. Language Detection in Code-Mixed Text
#%%
LANGID_SYSTEM = """Identify the languages mixed in this text.
Return JSON: {"languages": ["lang1", "lang2"], "mixing_pattern": "description"} /no_think"""

test_texts = [
    "yeh movie bahut acchi hai, must watch!",
    "La comida is amazing, highly recommend",
    "3ajabni kteer the acting, amazing work",
]
print("LANGUAGE IDENTIFICATION")
print("=" * 60)
for t in test_texts:
    resp = ask(LANGID_SYSTEM, f"Text: {t}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    if s >= 0 and e > s:
        try:
            result = json.loads(text[s:e])
            print(f"\n  {t}")
            print(f"  Languages: {', '.join(result.get('languages', []))}")
        except: print(f"\n  {t} -> parse error")
#%% md
## 9. Per-Mix-Type Accuracy
#%%
print("PER-MIX-TYPE ACCURACY")
print("=" * 40)
for mix_type in ["Hinglish", "Spanglish", "Arabizi"]:
    subset = [d for d in DATA if d["mix"] == mix_type]
    correct = 0
    for d in subset:
        resp = ask(CLASSIFY_SYSTEM, f"Text: {d['text']}")
        text = resp
        if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
        s, e = text.find("{"), text.rfind("}") + 1
        predicted = "neutral"
        if s >= 0 and e > s:
            try: predicted = json.loads(text[s:e]).get("sentiment", "neutral").lower()
            except: pass
        if predicted == d["sentiment"]: correct += 1
    print(f"  {mix_type:<12}: {correct}/{len(subset)} = {correct/len(subset):.0%}")
#%% md
## 10. Common Mistakes & Key Takeaways

| Mistake | Fix |
|---------|-----|
| Using word tokenizers | Use char-ngrams for code-mixed text |
| Training on monolingual data | Need code-mixed training data |
| One model per language | Use multilingual/LLM approach |

| # | Takeaway |
|---|----------|
| 1 | **Char n-grams** handle code-mixing better than word tokenizers |
| 2 | **LLMs handle code-mixing** zero-shot without task-specific training |
| 3 | **Performance varies by mix type** - always evaluate per-mix |
| 4 | **Language identification** helps route to specialized models |

