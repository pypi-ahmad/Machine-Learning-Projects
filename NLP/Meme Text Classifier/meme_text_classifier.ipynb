#%% md
# Meme Text Classifier

## 1. Project Overview
**Task:** Classify meme captions by theme (humor, sarcasm, political, wholesome) and sentiment.
**Stack:** `LangChain` + `ChatOllama` + `qwen3.5:9b`.
#%% md
## 2. Why This Matters
- Content moderation at scale
- Cultural trend analysis
- Sarcasm and irony are hard for rule-based systems
#%% md
## 3. Setup
#%%
from collections import Counter
import os, json, re, warnings
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0)

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply OK.', 'Test')[:20]}")
#%% md
## 4. Meme Captions
#%%
MEMES = [
    {"text": "When you finally fix the bug but create 3 more", "exp": "humor"},
    {"text": "Nobody: Me at 3am: reorganizing my entire life", "exp": "humor"},
    {"text": "My dog looking at me like I'm the greatest human", "exp": "wholesome"},
    {"text": "Politicians promising change vs actually delivering", "exp": "political"},
    {"text": "Oh sure let me just work overtime for free again", "exp": "sarcasm"},
    {"text": "POV: Your grandma learning FaceTime and loving it", "exp": "wholesome"},
    {"text": "The economy is fine. Everything is fine. This is fine.", "exp": "sarcasm"},
    {"text": "When WiFi goes down for 5 min and you become a philosopher", "exp": "humor"},
    {"text": "Corporate wants you to find the difference", "exp": "humor"},
    {"text": "Billionaires going to space while we can't afford rent", "exp": "political"},
    {"text": "Random stranger complimented my shirt, still thinking about it", "exp": "wholesome"},
]
print(f"Memes: {len(MEMES)}")
#%% md
---
## 5. Classification
#%%
CLS_SYS = \"\"\"Classify this meme caption.
Theme: humor, sarcasm, wholesome, political, relatable, absurd
Sentiment: positive, negative, neutral
Return JSON: {"theme":"...","sentiment":"...","sarcasm_detected":true/false} /no_think\"\"\"

print("MEME CLASSIFICATION")
print("=" * 70)
results = []
for m in MEMES:
    resp = ask(CLS_SYS, f"Meme: {m['text']}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    theme, sent = "?", "?"
    if s >= 0 and e > s:
        try:
            r = json.loads(text[s:e])
            theme, sent = r.get("theme","?"), r.get("sentiment","?")
        except: pass
    results.append({"text": m["text"], "theme": theme, "sentiment": sent})
    print(f"  [{theme:<10}] [{sent:<8}] {m['text'][:55]}...")
#%% md
## 6. Distribution
#%%
tc = Counter(r["theme"] for r in results)
print("THEME DISTRIBUTION")
for t, c in tc.most_common(): print(f"  {t:<15} {c:>2} {'#'*(c*3)}")
#%% md
## 7. Sarcasm Analysis
#%%
SAR_SYS = \"\"\"Is this sarcastic? Return JSON: {"is_sarcastic":true/false,"mechanism":"irony|exaggeration|deadpan","target":"what is mocked"} /no_think\"\"\"
print("SARCASM ANALYSIS")
for m in [x for x in MEMES if x["exp"]=="sarcasm"]:
    resp = ask(SAR_SYS, f"Text: {m['text']}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    if s >= 0 and e > s:
        try:
            r = json.loads(text[s:e])
            print(f"  {m['text'][:50]}...")
            print(f"    Mechanism: {r.get('mechanism','?')}, Target: {r.get('target','?')}\n")
        except: pass
#%% md
## 8. Key Takeaways

| # | Takeaway |
|---|----------|
| 1 | LLMs handle meme slang and irony well |
| 2 | Sarcasm detection needs implied-meaning understanding |
| 3 | Theme + sentiment gives richer classification |

