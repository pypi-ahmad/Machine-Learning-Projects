#%% md
# Crisis Signal Detector

## 1. Project Overview
**Task:** Detect urgent or distress-like messages for escalation to human responders.
**Stack:** `LangChain` + `ChatOllama` + `qwen3.5:9b`.

> **Important:** This is a learning project. Real crisis detection requires professional clinical validation.
#%% md
## 2. Why This Matters
- **False negatives are unacceptable** — missing a crisis is far worse than a false alarm
- Detect: self-harm ideation, domestic violence, substance crisis, mental health emergencies
- Triage by urgency for human responders
#%% md
## 3. Setup
#%%
import os, json, re, warnings
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0)

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply OK.', 'Test')[:20]}")
#%% md
## 4. Sample Messages
#%%
MESSAGES = [
    {"text": "Had a great day at the park with my kids!", "expected": "safe"},
    {"text": "I can't take this anymore, everything feels hopeless", "expected": "high_risk"},
    {"text": "My partner hit me again last night", "expected": "high_risk"},
    {"text": "Work has been stressful, need a vacation", "expected": "low_risk"},
    {"text": "I've been crying every day for weeks, nothing helps", "expected": "medium_risk"},
    {"text": "Just bought a new book, excited to read!", "expected": "safe"},
    {"text": "Nobody would notice if I was gone tomorrow", "expected": "high_risk"},
    {"text": "Feeling down today, probably just the weather", "expected": "low_risk"},
    {"text": "I've been stockpiling pills, I have a plan now", "expected": "critical"},
    {"text": "My anxiety is bad but therapy is helping", "expected": "low_risk"},
    {"text": "I need help, I'm scared of what my roommate might do", "expected": "high_risk"},
    {"text": "Broke up with girlfriend, sad but I'll be okay", "expected": "low_risk"},
]
print(f"Messages: {len(MESSAGES)}")
#%% md
---
## 5. Crisis Detection
#%%
CRISIS_SYS = \"\"\"Analyze for crisis signals. Err on caution.
Risk: safe, low_risk, medium_risk, high_risk, critical
Return JSON:
{"risk_level":"...","crisis_type":"none|mental_health|self_harm|domestic_violence|substance",
"confidence":0.0-1.0,"signals":["signal"],"recommended_action":"none|monitor|offer_resources|human_review|immediate_escalation",
"reasoning":"brief"} /no_think\"\"\"

print("CRISIS DETECTION")
print("=" * 80)
results = []
for m in MESSAGES:
    resp = ask(CRISIS_SYS, f"Message: {m['text']}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    r = {"risk_level":"?","crisis_type":"none"}
    if s >= 0 and e > s:
        try: r = json.loads(text[s:e])
        except: pass
    r["text"] = m["text"]
    r["expected"] = m["expected"]
    results.append(r)
    match = r.get("risk_level")==m["expected"] or (r.get("risk_level") in ("high_risk","critical") and m["expected"] in ("high_risk","critical"))
    print(f"  [{r.get('risk_level','?'):<11}] [{r.get('crisis_type','?'):<18}] {'OK' if match else '!!'} {m['text'][:40]}...")
#%% md
## 6. Escalation Queue
#%%
RO = {"critical":0,"high_risk":1,"medium_risk":2,"low_risk":3,"safe":4}
esc = [r for r in results if r.get("risk_level") in ("critical","high_risk","medium_risk")]
esc.sort(key=lambda x: RO.get(x.get("risk_level","safe"),5))
print("ESCALATION QUEUE")
print("=" * 70)
for r in esc:
    print(f"  [{r.get('risk_level','?'):<11}] Action: {r.get('recommended_action','?')}")
    print(f"    {r['text'][:60]}...")
    print(f"    Signals: {', '.join(r.get('signals',[]))[:60]}\n")
#%% md
## 7. Detection Accuracy
#%%
cd = sum(1 for r in results if r.get("risk_level") in ("high_risk","critical") and r["expected"] in ("high_risk","critical"))
ct = sum(1 for r in results if r["expected"] in ("high_risk","critical"))
missed = sum(1 for r in results if r.get("risk_level") in ("safe","low_risk") and r["expected"] in ("high_risk","critical"))
print(f"Crisis detected: {cd}/{ct}")
print(f"MISSED CRISES: {missed} (must be 0 in production)")
#%% md
## 8. Key Takeaways

| # | Takeaway |
|---|----------|
| 1 | **False negatives are unacceptable** — err on caution |
| 2 | Indirect language requires LLM understanding |
| 3 | Multi-type detection covers self-harm, DV, substance |
| 4 | Always pair with human reviewers |

