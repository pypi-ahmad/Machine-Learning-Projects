   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\"cell_type\":\"markdown\",\"metadata\":{},\"source\":[\"# Multilingual FAQ Bot\\n\",\"**NLP Project 66 of 100** — Same knowledge base, multiple answer languages using multilingual embeddings.\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"import subprocess, sys, importlib\\nfor pkg in ['numpy','sentence-transformers','scikit-learn','requests']:\\n    try: importlib.import_module(pkg.replace('-','_'))\\n    except ImportError: subprocess.check_call([sys.executable,'-m','pip','install','-q',pkg])\\nprint('Ready.')\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"import numpy as np, requests\\nfrom sentence_transformers import SentenceTransformer\\nfrom sklearn.metrics.pairwise import cosine_similarity\\nimport warnings; warnings.filterwarnings('ignore')\\nmodel = SentenceTransformer('paraphrase-multilingual-MiniLM-L12-v2')\\nprint('Loaded.')\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"# Knowledge base in English\\nKB = [\\n    'Our business hours are Monday to Friday, 9 AM to 6 PM EST.',\\n    'We accept Visa, Mastercard, PayPal, and bank transfers.',\\n    'Returns are accepted within 30 days of purchase with original receipt.',\\n    'Free shipping on orders over $50 within the continental US.',\\n    'Contact support at support@company.com or call 1-800-HELP.',\\n]\\nkb_embs = model.encode(KB)\\n\\ndef faq_search(query, top_k=1):\\n    q_emb = model.encode([query])\\n    sims = cosine_similarity(q_emb, kb_embs)[0]\\n    idx = sims.argmax()\\n    return KB[idx], round(float(sims[idx]), 3)\\n\\n# Test with multilingual queries\\nqueries = [\\n    ('What are your hours?', 'English'),\\n    ('¿Cuáles son sus horarios?', 'Spanish'),\\n    ('Quels sont vos horaires?', 'French'),\\n    ('Wie kann ich zurücksenden?', 'German'),  # How can I return?\\n]\\n\\nfor q, lang in queries:\\n    answer, score = faq_search(q)\\n    print(f'[{lang}] Q: {q}')\\n    print(f'  A ({score}): {answer}\\\\n')\"]},\n",
    "  {\"cell_type\":\"markdown\",\"metadata\":{},\"source\":[\"## Summary\\n\",\"- **Multilingual embeddings match queries across languages** to English KB.\\n\",\"- **One knowledge base serves multiple languages** without translation.\\n\",\"- **For production, translate the answer** into the query language using translation API.\"]}\n",
    " ],\n",
