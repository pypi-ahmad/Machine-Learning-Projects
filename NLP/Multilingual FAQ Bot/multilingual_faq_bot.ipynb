#%% md
# Multilingual FAQ Bot

## 1. Project Overview

**Task:** Answer questions in the user's language from a single English KB using multilingual embeddings and LLM.

**Stack:** `LangChain` + `ChatOllama` + `qwen3.5:9b`, `sentence-transformers` for multilingual embeddings.
#%% md
## 2. Learning Goals

| # | Skill |
|---|-------|
| 1 | **Build** a multilingual FAQ retrieval system |
| 2 | **Use** multilingual embeddings for cross-lingual matching |
| 3 | **Control** answer language using LLM system prompts |

## 3. Why This Matters

- **One KB, many languages** - maintain FAQ in English, serve users globally
- **Cost efficiency** - no need to translate FAQs for every language
#%% md
## 4. Setup
#%%
import os, json, re, warnings
import numpy as np
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage
from sentence_transformers import SentenceTransformer
from sklearn.metrics.pairwise import cosine_similarity

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0.2)
embed_model = SentenceTransformer("paraphrase-multilingual-MiniLM-L12-v2")

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply with one word.', 'Say ready.')[:20]}")
#%% md
## 5. Knowledge Base
#%%
KB = [
    {"id": 1, "category": "Hours", "answer": "Business hours: Monday-Friday, 9 AM - 6 PM EST. Weekend support via email only."},
    {"id": 2, "category": "Payment", "answer": "We accept Visa, Mastercard, PayPal, Apple Pay, and bank transfers."},
    {"id": 3, "category": "Returns", "answer": "Returns accepted within 30 days with original receipt. Items must be unused."},
    {"id": 4, "category": "Shipping", "answer": "Free shipping on orders over $50 (US). International: $15 flat rate. 3-7 business days."},
    {"id": 5, "category": "Support", "answer": "Email support@company.com, call 1-800-HELP, or use live chat. Response time: 2 hours."},
    {"id": 6, "category": "Warranty", "answer": "1-year limited warranty on all products. Covers manufacturing defects."},
]

kb_texts = [item["answer"] for item in KB]
kb_embeddings = embed_model.encode(kb_texts)
print(f"KB: {len(KB)} entries indexed")
#%% md
---
## 6. Multilingual FAQ Search
#%%
def faq_search(query, top_k=1):
    q_emb = embed_model.encode([query])
    sims = cosine_similarity(q_emb, kb_embeddings)[0]
    top_idx = np.argsort(sims)[::-1][:top_k]
    return [(KB[i], float(sims[i])) for i in top_idx]

QUERIES = [
    ("What are your business hours?", "English"),
    ("Cuales son sus horarios?", "Spanish"),
    ("Quels sont vos horaires?", "French"),
    ("Wie kann ich etwas zuruecksenden?", "German"),
    ("Quali metodi di pagamento accettate?", "Italian"),
]

print("MULTILINGUAL FAQ RETRIEVAL")
print("=" * 70)
for query, lang in QUERIES:
    results = faq_search(query, top_k=1)
    item, score = results[0]
    print(f"  [{lang}] Q: {query}")
    print(f"    Match ({score:.3f}): [{item['category']}] {item['answer'][:60]}...\n")
#%% md
## 7. Answer in User's Language
#%%
ANSWER_SYSTEM = """You are customer support. Use the FAQ answer to respond.
IMPORTANT: Answer in {language}. Keep it concise and helpful. /no_think"""

print("MULTILINGUAL ANSWERS")
print("=" * 70)
test_queries = [
    ("Cuales son sus horarios?", "Spanish"),
    ("Quels sont vos modes de paiement?", "French"),
    ("Wie kann ich etwas zuruecksenden?", "German"),
]
for query, lang in test_queries:
    results = faq_search(query, top_k=1)
    item, score = results[0]
    answer = ask(ANSWER_SYSTEM.format(language=lang), f"User: {query}\nFAQ: {item['answer']}")
    print(f"  [{lang}] Q: {query}")
    print(f"  A: {answer[:150]}\n")
#%% md
## 8. Retrieval Accuracy
#%%
EVAL_QUERIES = [
    ("What payment methods?", "Payment"),
    ("Aceptan PayPal?", "Payment"),
    ("Comment retourner un produit?", "Returns"),
    ("Gibt es kostenlosen Versand?", "Shipping"),
    ("Come posso contattare il supporto?", "Support"),
]

print("RETRIEVAL ACCURACY")
print("=" * 50)
correct = 0
for query, expected in EVAL_QUERIES:
    results = faq_search(query, top_k=1)
    item, score = results[0]
    match = item["category"] == expected
    if match: correct += 1
    print(f"  {'OK' if match else 'MISS'} ({score:.3f}) {query[:40]:<42} -> {item['category']}")
print(f"\nAccuracy: {correct}/{len(EVAL_QUERIES)} = {correct/len(EVAL_QUERIES):.0%}")
