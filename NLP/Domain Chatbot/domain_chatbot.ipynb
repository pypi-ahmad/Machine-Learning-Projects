## 7. Retrieval Engine

Semantic search over the knowledge base using cosine similarity.
#%%
def retrieve(query, top_k=3):
    """Retrieve top-k most relevant documents for a query."""
    q_emb = embedder.encode([query])
    sims = cosine_similarity(q_emb, kb_embeddings)[0]
    top_indices = sims.argsort()[-top_k:][::-1]
    results = []
    for idx in top_indices:
        results.append({"doc": KNOWLEDGE_BASE[idx], "score": float(sims[idx])})
    return results

test_queries = [
    "How do I create a list in Python?",
    "What are virtual environments used for?",
    "How do I handle errors and exceptions?",
    "What is async programming?",
]

print("RETRIEVAL TEST")
print("=" * 60)
for q in test_queries:
    results = retrieve(q, top_k=2)
    print(f"\nQ: {q}")
    for r in results:
        print(f"  [{r['score']:.3f}] {r['doc']['topic']}: {r['doc']['content'][:60]}...")
#%% md
## 8. Approach 1 — Retrieval Only (No LLM)

Return the top retrieved document directly as the answer.
#%%
def retrieval_only_answer(question):
    results = retrieve(question, top_k=1)
    if results and results[0]["score"] > 0.3:
        return results[0]["doc"]["content"]
    return "I don't have information on that topic in my knowledge base."

QUESTIONS = [
    "How do I create and use a dictionary in Python?",
    "What's the best way to handle exceptions?",
    "How do generators work and when should I use them?",
    "What is the meaning of life?",
    "How do I read and write files?",
    "What are type hints and how do I use them?",
]

print("RETRIEVAL-ONLY ANSWERS")
print("=" * 60)
for q in QUESTIONS:
    ans = retrieval_only_answer(q)
    print(f"\nQ: {q}")
    print(f"A: {ans[:150]}...")
#%% md
## 9. Approach 2 — LLM Only (No Retrieval)
#%%
LLM_ONLY_SYSTEM = "You are a Python programming assistant.\nAnswer the question concisely in 2-3 sentences.\nIf you are unsure, say so. /no_think"

print("LLM-ONLY ANSWERS")
print("=" * 60)
llm_only_results = {}
for q in QUESTIONS:
    ans = ask(LLM_ONLY_SYSTEM, q)
    llm_only_results[q] = ans
    print(f"\nQ: {q}")
    print(f"A: {ans[:200]}")
#%% md
## 10. Approach 3 — RAG Chatbot (Retrieval + LLM)

Retrieve relevant documents, inject as context, generate a grounded answer.
#%%
RAG_SYSTEM = """You are a Python programming assistant that answers ONLY from the provided context.

Rules:
- Answer using ONLY the information in the Context section
- If the context does not cover the question, say "I don't have that information in my knowledge base"
- Be concise (2-4 sentences)
- Cite which topic the answer comes from when possible
- Do not make up information beyond the context /no_think"""

def rag_answer(question, top_k=3):
    results = retrieve(question, top_k=top_k)
    context_parts = []
    for r in results:
        context_parts.append(f"[{r['doc']['topic']}] {r['doc']['content']}")
    context = "\n\n".join(context_parts)
    user_prompt = f"Context:\n{context}\n\nQuestion: {question}"
    answer = ask(RAG_SYSTEM, user_prompt)
    return {"answer": answer, "sources": [r["doc"]["topic"] for r in results], "scores": [r["score"] for r in results]}

print("RAG CHATBOT ANSWERS")
print("=" * 60)
rag_results = {}
for q in QUESTIONS:
    result = rag_answer(q)
    rag_results[q] = result
    print(f"\nQ: {q}")
    print(f"A: {result['answer']}")
    print(f"   Sources: {', '.join(result['sources'])} (scores: {', '.join(f'{s:.2f}' for s in result['scores'])})")
#%% md
## 11. Quality Evaluation — Three Approaches Compared
#%%
EVAL_SYSTEM = """You evaluate chatbot answers for a Python programming knowledge base.

Score each criterion 1-5:
1. relevance: Does the answer address the question? (1=off-topic, 5=directly answers)
2. groundedness: Is the answer based on factual information? (1=made up, 5=fully grounded)
3. completeness: Does the answer cover the key aspects? (1=missing most, 5=thorough)
4. conciseness: Is it appropriately brief? (1=rambling, 5=perfectly concise)

Return JSON: {"relevance": N, "groundedness": N, "completeness": N, "conciseness": N, "total": N, "note": "brief comment"} /no_think"""

def evaluate_answer(question, answer):
    resp = ask(EVAL_SYSTEM, f"Question: {question}\n\nAnswer: {answer}")
    text = resp
    if "```" in text: text = re.sub(r"```(?:json)?\s*", "", text).replace("```", "")
    s, e = text.find("{"), text.rfind("}") + 1
    if s >= 0 and e > s:
        try: return json.loads(text[s:e])
        except: pass
    return None

eval_questions = [q for q in QUESTIONS if q != "What is the meaning of life?"]

print("COMPARATIVE EVALUATION")
print("=" * 70)
print(f"{'Question':<45} {'Retrieval':>10} {'LLM-only':>10} {'RAG':>10}")
print("-" * 70)

approach_totals = {"Retrieval": [], "LLM-only": [], "RAG": []}
for q in eval_questions:
    row_label = (q[:42] + "...") if len(q) > 42 else q
    ret_ans = retrieval_only_answer(q)
    ret_eval = evaluate_answer(q, ret_ans)
    ret_score = sum(ret_eval.get(k, 0) for k in ["relevance","groundedness","completeness","conciseness"]) if ret_eval else 0
    approach_totals["Retrieval"].append(ret_score)
    llm_ans = llm_only_results.get(q, "N/A")
    llm_eval = evaluate_answer(q, llm_ans)
    llm_score = sum(llm_eval.get(k, 0) for k in ["relevance","groundedness","completeness","conciseness"]) if llm_eval else 0
    approach_totals["LLM-only"].append(llm_score)
    rag_res = rag_results.get(q, {})
    rag_ans = rag_res.get("answer", "N/A")
    rag_eval = evaluate_answer(q, rag_ans)
    rag_score = sum(rag_eval.get(k, 0) for k in ["relevance","groundedness","completeness","conciseness"]) if rag_eval else 0
    approach_totals["RAG"].append(rag_score)
    print(f"{row_label:<45} {ret_score:>7}/20 {llm_score:>7}/20 {rag_score:>7}/20")

print("-" * 70)
for approach, scores in approach_totals.items():
    avg = np.mean(scores) if scores else 0
    print(f"{'Average ' + approach:<45} {avg:>10.1f}/20")
#%% md
## 12. Multi-Turn Conversation
#%%
CONV_SYSTEM = """You are a Python programming assistant that answers from the provided context.
You also have access to the conversation history for follow-up questions.

Rules:
- Answer using the context and conversation history
- For follow-ups, refer back to previous answers when relevant
- Be concise (2-4 sentences)
- If the context doesn't cover the topic, say so /no_think"""

def chat_session(questions):
    history = []
    print("MULTI-TURN CONVERSATION")
    print("=" * 60)
    for q in questions:
        results = retrieve(q, top_k=2)
        context = "\n".join(f"[{r['doc']['topic']}] {r['doc']['content']}" for r in results)
        hist_text = ""
        if history:
            hist_text = "\nConversation so far:\n"
            hist_text += "\n".join(f"User: {h['q']}\nAssistant: {h['a']}" for h in history[-3:])
        user_prompt = f"Context:\n{context}{hist_text}\n\nUser question: {q}"
        answer = ask(CONV_SYSTEM, user_prompt)
        history.append({"q": q, "a": answer})
        print(f"\nUser: {q}")
        print(f"Bot:  {answer}")
    return history

conversation = chat_session([
    "How do I create a function in Python?",
    "Can I pass multiple arguments to it?",
    "How do I add type hints to those arguments?",
    "What about error handling inside functions?",
])
#%% md
## 13. Out-of-Domain Detection
#%%
OOD_QUESTIONS = [
    "What is the capital of France?",
    "How do I make a pizza?",
    "Explain quantum computing",
    "What Python testing frameworks exist?",
    "How do I slice a list?",
]

print("OUT-OF-DOMAIN DETECTION")
print("=" * 60)
for q in OOD_QUESTIONS:
    results = retrieve(q, top_k=1)
    top_score = results[0]["score"] if results else 0
    is_in_domain = top_score > 0.35
    answer = rag_answer(q) if is_in_domain else {"answer": "This question is outside my Python knowledge base.", "sources": [], "scores": [top_score]}
    status = "In-domain" if is_in_domain else "Out-of-domain"
    print(f"\nQ: {q}")
    print(f"   Relevance score: {top_score:.3f} -> {status}")
    print(f"   A: {answer['answer'][:150]}")
#%% md
## 14. Prompt Engineering Comparison
#%%
PROMPT_VARIANTS = {
    "Minimal": "Answer the question using the context. Be brief. /no_think",
    "Structured": "You are a Python tutor. Use the context to answer.\nFormat: start with a direct answer, then give one example if helpful.\nKeep under 3 sentences. /no_think",
    "Strict grounding": "You are a knowledge base assistant.\nONLY use information from the provided context.\nIf the context does not contain the answer, say 'Not covered in knowledge base.'\nNever add information beyond the context. /no_think",
}

test_q = "How do I handle errors in Python?"
results = retrieve(test_q, top_k=3)
context = "\n".join(f"[{r['doc']['topic']}] {r['doc']['content']}" for r in results)

print("PROMPT VARIANT COMPARISON")
print("=" * 60)
print(f"Question: {test_q}\n")
for name, system_prompt in PROMPT_VARIANTS.items():
    answer = ask(system_prompt, f"Context:\n{context}\n\nQuestion: {test_q}")
    print(f"--- {name} ({len(answer.split())} words) ---")
    print(f"{answer}\n")
