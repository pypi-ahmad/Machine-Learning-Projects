kb_texts = [doc["content"] for doc in KNOWLEDGE_BASE]
kb_embeddings = embedder.encode(kb_texts, show_progress_bar=False)

print(f"Knowledge base: {len(KNOWLEDGE_BASE)} documents")
print(f"Embedding shape: {kb_embeddings.shape}")
print(f"\nTopics covered:")
for doc in KNOWLEDGE_BASE:
    print(f"  {doc['id']:>2}. {doc['topic']}")
