#%% md
## 4. Setup
#%%
import os, json, re, warnings
os.environ["TOKENIZERS_PARALLELISM"] = "false"
warnings.filterwarnings("ignore")

from langchain_ollama import ChatOllama
from langchain_core.messages import HumanMessage, SystemMessage

LLM_MODEL = "qwen3.5:9b"
llm = ChatOllama(model=LLM_MODEL, temperature=0)

def clean(text):
    if "<think>" in text: text = text.split("</think>")[-1].strip()
    return text.strip()

def ask(system, user):
    return clean(llm.invoke([SystemMessage(content=system), HumanMessage(content=user)]).content)

print(f"LLM ready: {ask('Reply with one word.', 'Say ready.')[:20]}")
#%% md
## 5. Rule-Based Transliteration
#%%
LATIN_TO_DEVANAGARI = {
    "kha": "\u0916", "gha": "\u0918", "cha": "\u091A", "tha": "\u0925",
    "dha": "\u0927", "bha": "\u092D", "sha": "\u0936", "aa": "\u0906",
    "ee": "\u0908", "oo": "\u090A", "ka": "\u0915", "ga": "\u0917",
    "ja": "\u091C", "ta": "\u0924", "da": "\u0926", "na": "\u0928",
    "pa": "\u092A", "ba": "\u092C", "ma": "\u092E", "ya": "\u092F",
    "ra": "\u0930", "la": "\u0932", "va": "\u0935", "sa": "\u0938",
    "ha": "\u0939", "a": "\u0905", "i": "\u0907", "u": "\u0909",
}

def rule_transliterate(text, mapping):
    result, i = [], 0
    text_lower = text.lower()
    while i < len(text_lower):
        matched = False
        for length in [3, 2, 1]:
            chunk = text_lower[i:i+length]
            if chunk in mapping:
                result.append(mapping[chunk])
                i += length
                matched = True
                break
        if not matched:
            result.append(text_lower[i])
            i += 1
    return "".join(result)

test_names = ["namaste", "karma", "yoga", "guru", "dharma", "mumbai"]
print("RULE-BASED: Latin -> Devanagari")
print("=" * 40)
for name in test_names:
    print(f"  {name:<12} -> {rule_transliterate(name, LATIN_TO_DEVANAGARI)}")
#%% md
## 6. LLM-Powered Transliteration
#%%
TRANSLIT_SYSTEM = "Transliterate from {source} to {target}. Return ONLY the result. /no_think"

test_cases = [
    {"text": "namaste", "source": "Latin", "target": "Devanagari"},
    {"text": "Mumbai", "source": "Latin", "target": "Devanagari"},
    {"text": "Moscow", "source": "Latin", "target": "Cyrillic"},
    {"text": "Tokyo", "source": "Latin", "target": "Japanese Katakana"},
    {"text": "Muhammad", "source": "Latin", "target": "Arabic"},
]

print("LLM TRANSLITERATION")
print("=" * 60)
for tc in test_cases:
    result = ask(TRANSLIT_SYSTEM.format(source=tc["source"], target=tc["target"]), tc["text"])
    print(f"  {tc['text']:<12} -> [{tc['target']:<20}] {result}")
#%% md
## 7. Rule vs LLM Comparison
#%%
comparison_words = ["karma", "yoga", "guru", "namaste", "dharma"]
print("RULE vs LLM COMPARISON")
print("=" * 60)
for word in comparison_words:
    rule_r = rule_transliterate(word, LATIN_TO_DEVANAGARI)
    llm_r = ask(TRANSLIT_SYSTEM.format(source="Latin", target="Devanagari"), word)
    print(f"  {word:<12} Rule: {rule_r:<15} LLM: {llm_r}")
#%% md
## 8. Script Detection
#%%
DETECT_SYSTEM = """Identify the writing script. Return JSON:
{"primary_script": "Latin|Devanagari|Cyrillic|...", "language": "likely language"} /no_think"""

detect_texts = ["Hello World", "\u0928\u092E\u0938\u094D\u0924\u0947", "\u041F\u0440\u0438\u0432\u0435\u0442", "Hello \u0928\u092E\u0938\u094D\u0924\u0947"]
print("SCRIPT DETECTION")
print("=" * 60)
for text in detect_texts:
    resp = ask(DETECT_SYSTEM, f"Text: {text}")
    r = resp
    if "```" in r: r = re.sub(r"```(?:json)?\s*", "", r).replace("```", "")
    s, e = r.find("{"), r.rfind("}") + 1
    if s >= 0 and e > s:
        try:
            result = json.loads(r[s:e])
            print(f"  {text:<20} -> {result.get('primary_script','?')} ({result.get('language','?')})")
        except: print(f"  {text:<20} -> parse error")
