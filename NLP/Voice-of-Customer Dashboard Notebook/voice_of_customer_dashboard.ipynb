    "{\n",
    " \"cells\": [\n",
    "  {\"cell_type\":\"markdown\",\"metadata\":{},\"source\":[\"# Voice-of-Customer Dashboard Notebook\\n\",\"**NLP Project 87 of 100** — Summarize customer themes and pain points from feedback data.\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"import numpy as np, pandas as pd, matplotlib.pyplot as plt, seaborn as sns\\nfrom sklearn.feature_extraction.text import TfidfVectorizer\\nfrom sklearn.cluster import KMeans\\nimport warnings; warnings.filterwarnings('ignore')\\nsns.set_style('whitegrid')\\n%matplotlib inline\\nSEED = 42; rng = np.random.default_rng(SEED)\\nprint('Loaded.')\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"# Synthetic VoC data\\nthemes = {\\n    'Product Quality': ['Great product quality','Excellent build','Durable and reliable','High quality materials'] * 15,\\n    'Slow Support': ['Support is too slow','Waited 3 days for response','No reply from support','Terrible response times'] * 12,\\n    'Pricing Issues': ['Too expensive','Prices increased again','Not worth the price','Competitor is cheaper'] * 10,\\n    'Feature Requests': ['Need dark mode','Please add export to PDF','Want mobile app','Add API access'] * 8,\\n    'Onboarding': ['Setup was confusing','Hard to get started','Documentation is lacking','Need better tutorial'] * 9,\\n}\\n\\nrows = []\\nfor theme, feedbacks in themes.items():\\n    for f in feedbacks:\\n        sentiment = 'positive' if theme == 'Product Quality' else 'negative'\\n        rows.append({'feedback': f, 'theme': theme, 'sentiment': sentiment})\\n\\ndf = pd.DataFrame(rows).sample(frac=1, random_state=SEED).reset_index(drop=True)\\nprint(f'Shape: {df.shape}')\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"fig, axes = plt.subplots(1, 3, figsize=(16, 4))\\n\\n# Theme distribution\\ndf['theme'].value_counts().plot(kind='bar', ax=axes[0], color='steelblue')\\naxes[0].set_title('Feedback by Theme'); axes[0].tick_params(axis='x', rotation=30)\\n\\n# Sentiment split\\ndf['sentiment'].value_counts().plot(kind='pie', ax=axes[1], autopct='%1.0f%%', colors=['coral','steelblue'])\\naxes[1].set_title('Sentiment Distribution')\\n\\n# Theme x Sentiment\\npd.crosstab(df['theme'], df['sentiment']).plot(kind='barh', stacked=True, ax=axes[2], color=['coral','steelblue'])\\naxes[2].set_title('Theme by Sentiment')\\n\\nplt.tight_layout(); plt.show()\"]},\n",
    "  {\"cell_type\":\"code\",\"execution_count\":null,\"metadata\":{},\"outputs\":[],\"source\":[\"# Key metrics\\nprint('=== Voice of Customer Summary ===')\\nprint(f'Total feedback: {len(df)}')\\nprint(f'Negative rate: {(df[\\\"sentiment\\\"]==\\\"negative\\\").mean():.1%}')\\nprint(f'\\\\nTop pain points:')\\nfor theme in df[df['sentiment']=='negative']['theme'].value_counts().head(3).index:\\n    count = len(df[(df['theme']==theme) & (df['sentiment']=='negative')])\\n    print(f'  • {theme}: {count} mentions')\\nprint(f'\\\\nTop feature requests:')\\nfor _, r in df[df['theme']=='Feature Requests'].head(4).iterrows():\\n    print(f'  • {r[\\\"feedback\\\"]}')\"]},\n",
    "  {\"cell_type\":\"markdown\",\"metadata\":{},\"source\":[\"## Summary\\n\",\"- **VoC analysis surfaces the most critical customer pain points.**\\n\",\"- **Theme clustering organizes unstructured feedback** into actionable categories.\\n\",\"- **Negative feedback analysis drives product priorities.**\\n\",\"- **For production, automate weekly VoC reports** with trend tracking.\"]}\n",
