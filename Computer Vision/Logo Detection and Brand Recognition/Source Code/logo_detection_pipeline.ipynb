{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "lbr-001",
        "language": "markdown"
      },
      "source": [
        "# Logo Detection and Brand Recognition (Retrieval Pipeline)\n",
        "\n",
        "Notebook-first refactor for logo brand recognition using real Kaggle download, strict dataset validation, SigLIP-family embedding retrieval, and honest quantitative plus qualitative evaluation."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "lbr-002",
        "language": "markdown"
      },
      "source": [
        "## Dataset Source\n",
        "\n",
        "Kaggle dataset: https://www.kaggle.com/datasets/sshikamaru/logos-dataset\n",
        "\n",
        "This notebook downloads the dataset in-code, verifies files/labels/splits, then runs brand retrieval evaluation on real images."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-003",
        "language": "python"
      },
      "source": [
        "import importlib\n",
        "import subprocess\n",
        "import sys\n",
        "\n",
        "def ensure_package(import_name, pip_name=None):\n",
        "    package_name = pip_name or import_name\n",
        "    try:\n",
        "        importlib.import_module(import_name)\n",
        "    except ImportError:\n",
        "        subprocess.check_call([sys.executable, '-m', 'pip', 'install', '-q', package_name])\n",
        "\n",
        "ensure_package('kagglehub')\n",
        "ensure_package('numpy')\n",
        "ensure_package('pandas')\n",
        "ensure_package('matplotlib')\n",
        "ensure_package('torch')\n",
        "ensure_package('transformers')\n",
        "ensure_package('PIL', 'Pillow')\n",
        "ensure_package('sklearn', 'scikit-learn')\n",
        "print('Dependencies are ready.')"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-004",
        "language": "python"
      },
      "source": [
        "import json\n",
        "import os\n",
        "import random\n",
        "from pathlib import Path\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import torch\n",
        "from PIL import Image\n",
        "from IPython.display import display\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "SEED = 42\n",
        "random.seed(SEED)\n",
        "np.random.seed(SEED)\n",
        "torch.manual_seed(SEED)\n",
        "if torch.cuda.is_available():\n",
        "    torch.cuda.manual_seed_all(SEED)\n",
        "\n",
        "DEVICE = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
        "PROJECT_DIR = Path.cwd()\n",
        "ARTIFACTS_DIR = PROJECT_DIR / 'artifacts'\n",
        "ARTIFACTS_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "print(f'Device: {DEVICE}')\n",
        "print(f'Project directory: {PROJECT_DIR}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "lbr-005",
        "language": "markdown"
      },
      "source": [
        "## Real Dataset Download"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-006",
        "language": "python"
      },
      "source": [
        "import kagglehub\n",
        "\n",
        "if not os.getenv('KAGGLE_USERNAME') or not os.getenv('KAGGLE_KEY'):\n",
        "    raise EnvironmentError('Missing Kaggle credentials. Set KAGGLE_USERNAME and KAGGLE_KEY.')\n",
        "\n",
        "dataset_root = Path(kagglehub.dataset_download('sshikamaru/logos-dataset'))\n",
        "print(f'Dataset root: {dataset_root}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "lbr-007",
        "language": "markdown"
      },
      "source": [
        "## Data Verification: Files, Labels, and Splits"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-008",
        "language": "python"
      },
      "source": [
        "image_exts = {'.jpg', '.jpeg', '.png', '.bmp', '.webp'}\n",
        "image_paths = [p for p in dataset_root.rglob('*') if p.suffix.lower() in image_exts]\n",
        "if len(image_paths) == 0:\n",
        "    raise RuntimeError('No image files found in downloaded dataset.')\n",
        "\n",
        "sample_n = min(300, len(image_paths))\n",
        "corrupt = 0\n",
        "for p in random.sample(image_paths, sample_n):\n",
        "    try:\n",
        "        with Image.open(p) as img:\n",
        "            img.verify()\n",
        "    except Exception:\n",
        "        corrupt += 1\n",
        "if corrupt > 0:\n",
        "    raise RuntimeError(f'Corrupted images found in sample check: {corrupt}')\n",
        "\n",
        "rows = []\n",
        "for p in image_paths:\n",
        "    parent_label = p.parent.name.strip()\n",
        "    rows.append({'image_path': str(p), 'label': parent_label})\n",
        "df = pd.DataFrame(rows)\n",
        "df = df.drop_duplicates(subset=['image_path']).reset_index(drop=True)\n",
        "\n",
        "label_counts = df['label'].value_counts()\n",
        "df = df[df['label'].isin(label_counts[label_counts >= 3].index)].reset_index(drop=True)\n",
        "if df['label'].nunique() < 2:\n",
        "    raise RuntimeError('Insufficient class labels inferred from dataset folder structure.')\n",
        "\n",
        "def infer_split(path_str):\n",
        "    s = path_str.lower()\n",
        "    if 'train' in s:\n",
        "        return 'train'\n",
        "    if 'val' in s or 'valid' in s or 'dev' in s:\n",
        "        return 'val'\n",
        "    if 'test' in s:\n",
        "        return 'test'\n",
        "    return 'unknown'\n",
        "\n",
        "df['split'] = df['image_path'].apply(infer_split)\n",
        "if (df['split'] == 'unknown').all():\n",
        "    train_df, temp_df = train_test_split(df, test_size=0.30, random_state=SEED, stratify=df['label'])\n",
        "    val_df, test_df = train_test_split(temp_df, test_size=0.50, random_state=SEED, stratify=temp_df['label'])\n",
        "    train_df = train_df.assign(split='train')\n",
        "    val_df = val_df.assign(split='val')\n",
        "    test_df = test_df.assign(split='test')\n",
        "    df = pd.concat([train_df, val_df, test_df], ignore_index=True)\n",
        "\n",
        "split_counts = df['split'].value_counts().to_dict()\n",
        "if split_counts.get('train', 0) == 0 or split_counts.get('val', 0) == 0 or split_counts.get('test', 0) == 0:\n",
        "    raise RuntimeError(f'Split verification failed: {split_counts}')\n",
        "\n",
        "print(f'Usable images: {len(df)}')\n",
        "print(f'Classes: {df["label"].nunique()}')\n",
        "print(f'Split counts: {split_counts}')\n",
        "display(df.head(8))"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-009",
        "language": "python"
      },
      "source": [
        "viz_df = df.sample(n=min(9, len(df)), random_state=SEED).reset_index(drop=True)\n",
        "fig, axes = plt.subplots(3, 3, figsize=(12, 10))\n",
        "for i in range(len(viz_df)):\n",
        "    ax = axes.flatten()[i]\n",
        "    row = viz_df.iloc[i]\n",
        "    img = Image.open(row['image_path']).convert('RGB')\n",
        "    ax.imshow(img)\n",
        "    ax.set_title(str(row['label'])[:24])\n",
        "    ax.axis('off')\n",
        "for j in range(len(viz_df), 9):\n",
        "    axes.flatten()[j].axis('off')\n",
        "plt.tight_layout()\n",
        "sample_grid = ARTIFACTS_DIR / 'dataset_samples.png'\n",
        "plt.savefig(sample_grid, dpi=140)\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "lbr-010",
        "language": "markdown"
      },
      "source": [
        "## Retrieval Model Setup (SigLIP-family)"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-011",
        "language": "python"
      },
      "source": [
        "from transformers import AutoProcessor, AutoModel\n",
        "\n",
        "model_candidates = ['google/siglip2-base-patch16-224', 'google/siglip-base-patch16-224']\n",
        "processor = None\n",
        "model = None\n",
        "selected_model = None\n",
        "for name in model_candidates:\n",
        "    try:\n",
        "        processor = AutoProcessor.from_pretrained(name)\n",
        "        model = AutoModel.from_pretrained(name).to(DEVICE)\n",
        "        selected_model = name\n",
        "        break\n",
        "    except Exception:\n",
        "        continue\n",
        "if selected_model is None:\n",
        "    raise RuntimeError('Could not load SigLIP/SigLIP2 model for retrieval.')\n",
        "model.eval()\n",
        "print(f'Embedding model: {selected_model}')"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-012",
        "language": "python"
      },
      "source": [
        "train_df = df[df['split'] == 'train'].reset_index(drop=True)\n",
        "val_df = df[df['split'] == 'val'].reset_index(drop=True)\n",
        "\n",
        "def get_embedding(image_path):\n",
        "    img = Image.open(image_path).convert('RGB')\n",
        "    inputs = processor(images=img, return_tensors='pt').to(DEVICE)\n",
        "    with torch.no_grad():\n",
        "        outputs = model(**inputs)\n",
        "    if hasattr(outputs, 'image_embeds') and outputs.image_embeds is not None:\n",
        "        emb = outputs.image_embeds[0]\n",
        "    else:\n",
        "        emb = outputs.last_hidden_state[:, 0, :][0]\n",
        "    emb = emb / torch.norm(emb)\n",
        "    return emb.detach().cpu().numpy()\n",
        "\n",
        "gallery_paths = train_df['image_path'].tolist()\n",
        "gallery_labels = train_df['label'].tolist()\n",
        "gallery_emb = np.vstack([get_embedding(p) for p in gallery_paths])\n",
        "\n",
        "print(f'Gallery samples: {len(gallery_paths)}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "lbr-013",
        "language": "markdown"
      },
      "source": [
        "## Real Evaluation: Retrieval Metrics"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-014",
        "language": "python"
      },
      "source": [
        "eval_df = val_df.sample(n=min(300, len(val_df)), random_state=SEED).reset_index(drop=True)\n",
        "\n",
        "rows = []\n",
        "r1_hits = 0\n",
        "r5_hits = 0\n",
        "\n",
        "for i in range(len(eval_df)):\n",
        "    q_path = eval_df.loc[i, 'image_path']\n",
        "    q_label = eval_df.loc[i, 'label']\n",
        "    q_emb = get_embedding(q_path)\n",
        "    sims = gallery_emb @ q_emb\n",
        "    top_idx = np.argsort(-sims)[:5]\n",
        "    top_labels = [gallery_labels[j] for j in top_idx]\n",
        "    top_scores = [float(sims[j]) for j in top_idx]\n",
        "\n",
        "    hit1 = int(top_labels[0] == q_label)\n",
        "    hit5 = int(q_label in top_labels)\n",
        "    r1_hits += hit1\n",
        "    r5_hits += hit5\n",
        "\n",
        "    rows.append({\n",
        "        'query_path': q_path,\n",
        "        'query_label': q_label,\n",
        "        'top1_label': top_labels[0],\n",
        "        'top1_score': top_scores[0],\n",
        "        'top5_labels': '|'.join(top_labels),\n",
        "        'hit@1': hit1,\n",
        "        'hit@5': hit5\n",
        "    })\n",
        "\n",
        "results_df = pd.DataFrame(rows)\n",
        "recall_at_1 = r1_hits / len(results_df)\n",
        "recall_at_5 = r5_hits / len(results_df)\n",
        "\n",
        "print(f'Evaluated queries: {len(results_df)}')\n",
        "print(f'Recall@1: {recall_at_1:.4f}')\n",
        "print(f'Recall@5: {recall_at_5:.4f}')\n",
        "display(results_df.head(10))"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-015",
        "language": "python"
      },
      "source": [
        "fig, axes = plt.subplots(1, 2, figsize=(8, 4))\n",
        "axes[0].bar(['Recall@1', 'Recall@5'], [recall_at_1, recall_at_5])\n",
        "axes[0].set_ylim(0, 1)\n",
        "axes[0].set_title('Retrieval Recall')\n",
        "\n",
        "top1_acc_by_class = results_df.groupby('query_label')['hit@1'].mean().sort_values(ascending=False).head(12)\n",
        "axes[1].barh(top1_acc_by_class.index.tolist(), top1_acc_by_class.values.tolist())\n",
        "axes[1].set_xlim(0, 1)\n",
        "axes[1].set_title('Top classes by Recall@1')\n",
        "\n",
        "plt.tight_layout()\n",
        "metrics_plot = ARTIFACTS_DIR / 'retrieval_metrics.png'\n",
        "plt.savefig(metrics_plot, dpi=140)\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "lbr-016",
        "language": "markdown"
      },
      "source": [
        "## Honest Qualitative Review"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-017",
        "language": "python"
      },
      "source": [
        "qual = results_df.sample(n=min(4, len(results_df)), random_state=SEED).reset_index(drop=True)\n",
        "fig, axes = plt.subplots(2, 2, figsize=(10, 10))\n",
        "for i in range(len(qual)):\n",
        "    row = qual.iloc[i]\n",
        "    ax = axes.flatten()[i]\n",
        "    img = Image.open(row['query_path']).convert('RGB')\n",
        "    ax.imshow(img)\n",
        "    ax.set_title(f\"GT: {row['query_label']}\\nTop1: {row['top1_label']}\")\n",
        "    ax.axis('off')\n",
        "for j in range(len(qual), 4):\n",
        "    axes.flatten()[j].axis('off')\n",
        "plt.tight_layout()\n",
        "qual_plot = ARTIFACTS_DIR / 'qualitative_retrieval.png'\n",
        "plt.savefig(qual_plot, dpi=140)\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "lbr-018",
        "language": "markdown"
      },
      "source": [
        "## Save Real Outputs"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "lbr-019",
        "language": "python"
      },
      "source": [
        "results_csv = ARTIFACTS_DIR / 'retrieval_results.csv'\n",
        "results_df.to_csv(results_csv, index=False)\n",
        "\n",
        "metrics = {\n",
        "    'dataset': 'sshikamaru/logos-dataset',\n",
        "    'dataset_root': str(dataset_root),\n",
        "    'num_images_used': int(len(df)),\n",
        "    'num_classes': int(df['label'].nunique()),\n",
        "    'split_counts': {k: int(v) for k, v in df['split'].value_counts().to_dict().items()},\n",
        "    'embedding_model': selected_model,\n",
        "    'num_eval_queries': int(len(results_df)),\n",
        "    'recall_at_1': float(recall_at_1),\n",
        "    'recall_at_5': float(recall_at_5)\n",
        "}\n",
        "\n",
        "metrics_json = ARTIFACTS_DIR / 'metrics.json'\n",
        "with open(metrics_json, 'w', encoding='utf-8') as f:\n",
        "    json.dump(metrics, f, indent=2)\n",
        "\n",
        "manifest = {\n",
        "    'dataset_url': 'https://www.kaggle.com/datasets/sshikamaru/logos-dataset',\n",
        "    'results_csv': str(results_csv),\n",
        "    'metrics_json': str(metrics_json),\n",
        "    'sample_grid_png': str(sample_grid),\n",
        "    'metrics_plot_png': str(metrics_plot),\n",
        "    'qualitative_png': str(qual_plot)\n",
        "}\n",
        "manifest_json = ARTIFACTS_DIR / 'artifact_manifest.json'\n",
        "with open(manifest_json, 'w', encoding='utf-8') as f:\n",
        "    json.dump(manifest, f, indent=2)\n",
        "\n",
        "print('Saved outputs:')\n",
        "print(f'- {results_csv}')\n",
        "print(f'- {metrics_json}')\n",
        "print(f'- {manifest_json}')\n",
        "print(f'- {sample_grid}')\n",
        "print(f'- {metrics_plot}')\n",
        "print(f'- {qual_plot}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "lbr-020",
        "language": "markdown"
      },
      "source": [
        "## Limitations and Improvements\n",
        "\n",
        "- This notebook implements retrieval-focused brand recognition, which is appropriate when detection boxes are not reliably annotated in YOLO format.\n",
        "- For scene-level logo localization mAP, add or convert to bounding-box annotations and train a YOLO26m detector.\n",
        "- Retrieval quality can improve with stronger augmentations and a domain-specific contrastive fine-tuning stage."
      ]
    }
