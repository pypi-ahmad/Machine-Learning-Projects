# ══════════════════════════════════════════════════════════════
#  .gitignore — Machine Learning Projects
# ══════════════════════════════════════════════════════════════

# ── Virtual Environments ──
venv/
env/
.env/
.venv/
Lib/

# ── Python Cache ──
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
*.dist-info/
site-packages/

# ── Jupyter Notebook ──
.ipynb_checkpoints/
*.ipynb_checkpoints/

# ── IDE / Editor ──
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OS Files ──
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Model Artifacts & Serialized Objects ──
*.h5
*.hdf5
*.pkl
*.pickle
*.sav
*.joblib
*.pb
*.pth
*.pt
*.onnx
*.tflite
saved_model/
checkpoints/

# ── Large Data Files (>90MB GitHub limit) ──
# Centralized data directory (6.7 GB — each project has its own dataset copy)
data/

# Block by extension
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z
*.gz
*.parquet
*.feather
*.arrow

# ── Audit & Internal Tooling ──
audit_phase1/
audit_phase2/
audit_phase3/
audit_phase5/
audit_phase6/
audit_phase8/
audit_scripts/

# ── Logs ──
*.log
logs/
logs.log

# ── pytest Cache ──
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── Miscellaneous ──
*.tmp
*.bak
*.orig