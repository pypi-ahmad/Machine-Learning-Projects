# ==============================================================================
# Deep Learning Projects Monorepo — .gitignore
# ==============================================================================

# ─── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
Lib/

# ─── IDE & Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Python Cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ─── Jupyter / Notebook ──────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Installed Packages ──────────────────────────────────────────────────────
*.dist-info/
site-packages/
*.egg-info/

# ─── Model Weights & Checkpoints ─────────────────────────────────────────────
*.pt
*.pth
*.ckpt
*.h5
*.hdf5
*.pb
*.tflite
*.onnx
*.caffemodel
*.model
*.safetensors
*.bin
*.joblib
*.pkl

# ─── Data & Datasets ─────────────────────────────────────────────────────────
datasets/
data/
outputs/
logs/
artifacts/
temp/
tmp/
catboost_info/

# ─── Experiment Tracking ─────────────────────────────────────────────────────
wandb/
mlruns/
lightning_logs/
mlflow.db
reports/

# ─── Large Files (use Git LFS for files > 95 MB) ─────────────────────────────
# Recommendation: install Git LFS and track large binaries with:
#   git lfs install
#   git lfs track "*.zip"
#   git lfs track "*.7z"
# etc.
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tar.bz2
*.npy
*.npz
*.csv
*.tsv
*.parquet
*.feather

# ─── Kaggle ───────────────────────────────────────────────────────────────────
.kaggle/
kaggle.json

# ─── System Files ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
# Claude Code local preferences (personal, not versioned)
CLAUDE.local.md
